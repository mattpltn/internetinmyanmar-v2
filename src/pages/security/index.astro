---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import ArticleList from '../../components/ArticleList.astro'
import { digestToArticle } from '../../utils/digestToArticle'

export const prerender = true

const [articleEntries, digestEntries] = await Promise.all([
  getCollection('articles', ({ data }) =>
    !data.draft && !data.archived && data.categories.includes('VPN & Security') && data.lang === 'en'
  ),
  getCollection('digest', ({ data }) =>
    !data.draft && data.category === 'Surveillance'
  ),
])

const combined = [
  ...articleEntries,
  ...digestEntries.map(digestToArticle),
].sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="VPN & Security Guides — Myanmar"
  seoTitle="VPN & Digital Security Guides Myanmar | Internet in Myanmar"
  metaDescription="Guides on using VPNs, protecting your privacy, and staying secure online in Myanmar. Tools for circumventing censorship and surveillance."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">VPN & Security</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">VPN & Security</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Practical guides for using VPNs, circumventing censorship, and protecting your digital privacy and security in Myanmar.
    </p>
    <ArticleList articles={combined} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
