---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import ArticleList from '../../components/ArticleList.astro'
import { digestToArticle } from '../../utils/digestToArticle'

export const prerender = true

const [articleEntries, digestEntries] = await Promise.all([
  getCollection('articles', ({ data }) =>
    !data.draft && !data.unlisted && !data.archived && data.categories.includes('Policy & Regulation') && data.lang === 'en'
  ),
  getCollection('digest', ({ data }) =>
    !data.draft && data.category === 'Policy'
  ),
])

const combined = [
  ...articleEntries,
  ...digestEntries.map(digestToArticle),
].sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Policy & Regulation — Myanmar"
  seoTitle="Myanmar Telecom Policy & Cyber Law | Internet in Myanmar"
  metaDescription="Analysis of Myanmar's digital policy landscape: cyber laws, telecom regulation, digital economy strategy, and their impact on internet freedom."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-warning)] mb-3 uppercase tracking-widest">Policy & Regulation</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Policy & Regulation</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Tracking Myanmar's digital policy landscape — cyber security laws, telecom regulation, digital economy strategies, and how regulatory decisions shape internet access and freedom.
    </p>
    <ArticleList articles={combined} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
