---
import Observatory from '../../layouts/Observatory.astro'
import asnStatusRaw   from '../../data/asn-status.json'
import outagesRaw     from '../../data/bgp-outages.json'
import historyRaw     from '../../data/bgp-history.json'
import metadataRaw    from '../../data/asn-metadata.json'
import stats          from '../../content/observatory/stats.json'
import { buildChartData }   from '../../lib/chart-data'
import { buildLeaderboards } from '../../lib/leaderboard'
import { BADGES } from '../../lib/asn-utils'
import type { NetworkType, AsnMeta } from '../../lib/asn-utils'

export const prerender = true

const asnStatus: Record<string, any>    = asnStatusRaw as any
const outages:   any[]                  = outagesRaw   as any
const history:   any[]                  = historyRaw   as any
const metadata:  Record<string, AsnMeta> = metadataRaw as any

// ── Status helpers ────────────────────────────────────────────────────────────

const OFF_THRESHOLD_MS = 7 * 24 * 3600 * 1000  // 7 days

function isOff(asn: any): boolean {
  if (asn.status !== 'RED') return false
  if (!asn.status_since) return false
  return Date.now() - new Date(asn.status_since).getTime() > OFF_THRESHOLD_MS
}

function statusColor(asn: any): string {
  if (isOff(asn))              return '#475569'
  if (asn.status === 'GREEN')  return '#22c55e'
  if (asn.status === 'YELLOW') return '#f59e0b'
  if (asn.status === 'RED')    return '#ef4444'
  return '#475569'
}

function statusLabel(asn: any): string {
  if (isOff(asn))              return 'OFF'
  if (asn.status === 'GREEN')  return 'UP'
  if (asn.status === 'YELLOW') return 'RECOVERING'
  if (asn.status === 'RED')    return 'DOWN'
  return 'UNKNOWN'
}

function statusPriority(asn: any): number {
  if (isOff(asn)) return 4
  const m: Record<string, number> = { RED: 0, YELLOW: 1, GREEN: 2, UNKNOWN: 5 }
  return m[asn.status] ?? 5
}

// ── Derive status-change events with downtime ─────────────────────────────────

interface StatusEvent {
  timestamp: string; asn: string; name: string; description: string
  from: string; to: string; visibility_pct: number
  downtime_minutes: number | null   // null = went down, not yet recovered
}

const statusEvents: StatusEvent[] = []
const lastDown: Record<string, string> = {}   // asn → timestamp when it went RED

for (let i = 1; i < history.length; i++) {
  const prev = history[i - 1].statuses ?? {}
  const curr = history[i].statuses   ?? {}
  for (const asn of Object.keys(curr)) {
    const prevStatus = prev[asn]?.status ?? 'UNKNOWN'
    const currStatus = curr[asn]?.status
    if (!currStatus || currStatus === prevStatus) continue

    let downtime_minutes: number | null = null

    if (currStatus === 'RED') {
      // Only record a new offline event if not already tracking this ASN as down
      if (lastDown[asn]) continue
      lastDown[asn] = history[i].timestamp
    } else if ((currStatus === 'GREEN' || currStatus === 'YELLOW') && prevStatus === 'RED') {
      if (lastDown[asn]) {
        const downMs  = new Date(history[i].timestamp).getTime() - new Date(lastDown[asn]).getTime()
        downtime_minutes = Math.round(downMs / 60000)
        delete lastDown[asn]
      }
    }

    const meta = metadata[asn]
    statusEvents.push({
      timestamp: history[i].timestamp, asn,
      name: asnStatus[asn]?.name ?? asn,
      description: meta?.description ?? asnStatus[asn]?.name ?? asn,
      from: prevStatus, to: currStatus,
      visibility_pct: curr[asn]?.visibility_pct ?? 0,
      downtime_minutes,
    })
  }
}
statusEvents.sort((a, b) => b.timestamp.localeCompare(a.timestamp))
// Pass all events to client (filtered client-side by time window)
const allEvents = statusEvents

// ── Build ASN rows for client-side table ──────────────────────────────────────

const allASNs = Object.values(asnStatus)
allASNs.sort((a, b) => statusPriority(a) - statusPriority(b))

interface TableRow {
  asn: string; asName: string; description: string
  type: string; status: string; statusLabel: string
  statusPriority: number; statusColor: string
  visibility: number | null; since: string; off: boolean
}

const tableRows: TableRow[] = allASNs.map(asn => {
  const meta    = metadata[asn.asn]
  const netType = (meta?.type ?? 'ISP') as NetworkType
  const off     = isOff(asn)
  return {
    asn:           asn.asn,
    asName:        asn.name ?? asn.asn,
    description:   meta?.description ?? asn.name ?? asn.asn,
    type:          netType,
    status:        asn.status ?? 'UNKNOWN',
    statusLabel:   statusLabel(asn),
    statusPriority: statusPriority(asn),
    statusColor:   statusColor(asn),
    visibility:    asn.visibility_pct != null ? Math.round(asn.visibility_pct * 100) : null,
    since:         asn.status_since ?? '',
    off,
  }
})

const downCount   = allASNs.filter(a => a.status === 'RED' && !isOff(a)).length
const yellowCount = allASNs.filter(a => a.status === 'YELLOW').length
const offCount    = allASNs.filter(a => isOff(a)).length
const totalCount  = allASNs.length

// ── Chart + leaderboard ───────────────────────────────────────────────────────

const chartData    = buildChartData(outages)
const leaderboards = buildLeaderboards(outages, metadata)

// ── Misc helpers ──────────────────────────────────────────────────────────────

function fmtTs(iso: string): string {
  return iso.replace('T', ' ').slice(0, 16) + ' UTC'
}

function fmtDowntime(min: number | null): string {
  if (min === null) return '—'
  const h = Math.floor(min / 60); const m = min % 60
  return h > 0 ? `${h}h ${m}m` : `${m}m`
}

function eventIcon(from: string, to: string): string {
  if (to === 'RED')    return '🔴'
  if (to === 'GREEN')  return '🟢'
  if (to === 'YELLOW') return '🟡'
  return '⚪'
}

function eventVerb(from: string, to: string): string {
  if (to === 'RED'    && from !== 'RED')    return 'went offline'
  if (to === 'GREEN'  && from === 'RED')    return 'back online'
  if (to === 'YELLOW' && from === 'RED')    return 'partially recovering'
  if (to === 'GREEN'  && from === 'YELLOW') return 'fully stabilised'
  return `→ ${to}`
}
---

<style>
  /* Tooltip on column headers */
  [data-tip] {
    position: relative; cursor: help;
  }
  [data-tip]::after {
    content: attr(data-tip);
    position: absolute; bottom: calc(100% + 6px); left: 50%;
    transform: translateX(-50%);
    background: #1e293b; color: #e2e8f0;
    font-size: 11px; font-family: 'Berkeley Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-weight: normal; text-transform: none; letter-spacing: 0;
    white-space: nowrap; padding: 5px 8px; border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.1);
    pointer-events: none; opacity: 0; transition: opacity 0.15s;
    z-index: 50;
  }
  [data-tip]:hover::after { opacity: 1; }

  /* Active filter/sort button */
  .btn-active {
    background: rgba(0,212,200,0.12) !important;
    border-color: rgba(0,212,200,0.4) !important;
    color: #7170ff !important;
  }

  /* Sort arrows */
  th.sortable { cursor: pointer; user-select: none; }
  th.sortable:hover { opacity: 1 !important; }
  th .sort-arrow { opacity: 0.3; margin-left: 3px; font-size: 9px; }
  th.sort-asc  .sort-arrow::after { content: '▲'; opacity: 1; }
  th.sort-desc .sort-arrow::after { content: '▼'; opacity: 1; }
</style>

<Observatory
  title="BGP Network Status — Myanmar ASNs"
  seoTitle="Myanmar BGP Network Status | Internet in Myanmar"
  metaDescription={`Real-time BGP routing status for ${totalCount} Myanmar autonomous systems. Detects internet shutdowns via global route collector data.`}
  lastUpdated={stats.lastUpdated}
  dataSource="RIPEstat (RIPE NCC), IODA (Georgia Tech)"
  datasetName="Myanmar BGP Network Outages"
  datasetDescription={`Real-time tracking of BGP route withdrawals for ${totalCount} Myanmar autonomous systems (ASNs). Sourced from RIPEstat global route collectors and IODA.`}
  pageUrl="https://www.internetinmyanmar.com/observatory/bgp/"
>

  <!-- Embedded data for client-side rendering -->
  <script id="chart-data"  type="application/json" set:html={JSON.stringify(chartData)}    />
  <script id="lb-data"     type="application/json" set:html={JSON.stringify(leaderboards)} />
  <script id="table-data"  type="application/json" set:html={JSON.stringify(tableRows)}    />
  <script id="events-data" type="application/json" set:html={JSON.stringify(allEvents)}    />

  <div class="space-y-12">

    <!-- Page intro -->
    <div>
      <p class="opacity-70 max-w-3xl text-sm">
        Real-time BGP routing visibility for all Myanmar autonomous systems, sourced from
        <a href="https://stat.ripe.net" target="_blank" rel="noopener" class="underline hover:opacity-100">RIPEstat</a>'s
        800+ global route collectors. When an ISP is ordered offline, its BGP prefixes withdraw within minutes — before any news report.
      </p>
      <p class="text-xs font-mono opacity-40 mt-2">
        🟢 UP (stable &gt;1h) &nbsp;·&nbsp;
        🟡 RECOVERING (back online &lt;1h) &nbsp;·&nbsp;
        🔴 DOWN (BGP withdrawn) &nbsp;·&nbsp;
        ⬛ OFF (dark &gt;7 days) &nbsp;·&nbsp;
        Updated every 5–30 min via VPS cron
      </p>
    </div>

    <!-- ── 4 stat cards ─────────────────────────────────────────────────────── -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="border border-white/10 rounded-lg p-5">
        <div class="font-mono text-xs opacity-40 uppercase tracking-widest mb-1">Monitored</div>
        <div class="text-3xl font-bold">{totalCount}</div>
        <div class="text-xs opacity-50 mt-1">Myanmar ASNs</div>
      </div>
      <div class={`border rounded-lg p-5 ${downCount > 0 ? 'border-[#ef4444]/40 bg-[#ef4444]/5' : 'border-white/10'}`}>
        <div class="font-mono text-xs opacity-40 uppercase tracking-widest mb-1">Currently down</div>
        <div class="text-3xl font-bold" style={downCount > 0 ? 'color:#ef4444' : ''}>{downCount}</div>
        <div class="text-xs opacity-50 mt-1">BGP withdrawal detected</div>
      </div>
      <div class={`border rounded-lg p-5 ${yellowCount > 0 ? 'border-[#f59e0b]/40 bg-[#f59e0b]/5' : 'border-white/10'}`}>
        <div class="font-mono text-xs opacity-40 uppercase tracking-widest mb-1">Recovering</div>
        <div class="text-3xl font-bold" style={yellowCount > 0 ? 'color:#f59e0b' : ''}>{yellowCount}</div>
        <div class="text-xs opacity-50 mt-1">Back online, monitoring</div>
      </div>
      <div class={`border rounded-lg p-5 ${offCount > 0 ? 'border-slate-500/40 bg-slate-500/5' : 'border-white/10'}`}>
        <div class="font-mono text-xs opacity-40 uppercase tracking-widest mb-1">Long-term off</div>
        <div class="text-3xl font-bold" style={offCount > 0 ? 'color:#475569' : ''}>{offCount}</div>
        <div class="text-xs opacity-50 mt-1">Dark &gt;7 days</div>
      </div>
    </div>

    <!-- ── Leaderboard ──────────────────────────────────────────────────────── -->
    <div>
      <h2 class="font-headline text-xl mb-1">Most Disrupted Networks</h2>
      <p class="text-sm opacity-50 mb-3">BGP withdrawal events by network. Rank by outage count, then total downtime.</p>

      <div class="flex flex-wrap gap-3 mb-4 items-center">
        <div class="flex gap-1">
          {(['7d','30d','90d'] as const).map(w => (
            <button class="lb-win-btn font-mono text-xs px-3 py-1 rounded border border-white/10 hover:border-white/30 transition-colors"
                    data-win={w} data-active={w === '7d' ? 'true' : undefined}>
              {w === '7d' ? '7 days' : w === '30d' ? '30 days' : '90 days'}
            </button>
          ))}
        </div>
        <div class="flex gap-1">
          <button class="lb-flap-btn font-mono text-xs px-3 py-1 rounded border border-white/10 hover:border-white/30 transition-colors"
                  data-filter="all" data-active="true">All outages</button>
          <button class="lb-flap-btn font-mono text-xs px-3 py-1 rounded border border-white/10 hover:border-white/30 transition-colors"
                  data-filter="significant">Significant only (&gt;5 min)</button>
        </div>
      </div>

      <div id="leaderboard-rows" class="space-y-1.5"></div>
      <p class="text-xs font-mono opacity-30 mt-3">
        ⚠ Outages under 5 min may be route flapping (BGP instability), not deliberate shutdown.
      </p>
    </div>

    <!-- ── Outage history chart ─────────────────────────────────────────────── -->
    <div>
      <h2 class="font-headline text-xl mb-1">Outage Event History</h2>

      <div class="flex flex-wrap gap-3 mb-4 items-center">
        <div class="flex gap-1">
          {(['1w','1m','3m','12m'] as const).map(w => (
            <button class="chart-win-btn font-mono text-xs px-3 py-1 rounded border border-white/10 hover:border-white/30 transition-colors"
                    data-win={w} data-active={w === '1w' ? 'true' : undefined}>
              {w === '1w' ? '1 week' : w === '1m' ? '1 month' : w === '3m' ? '3 months' : '12 months'}
            </button>
          ))}
        </div>
        <div class="flex gap-1">
          <button class="chart-flap-btn font-mono text-xs px-3 py-1 rounded border border-white/10 hover:border-white/30 transition-colors"
                  data-filter="all" data-active="true">All</button>
          <button class="chart-flap-btn font-mono text-xs px-3 py-1 rounded border border-white/10 hover:border-white/30 transition-colors"
                  data-filter="significant">Significant (&gt;5 min)</button>
        </div>
      </div>

      <div id="chart-subtitle" class="text-xs font-mono opacity-40 mb-2"></div>
      <div class="border border-white/10 rounded-lg p-4" style="height:200px">
        <canvas id="outage-chart" style="width:100%;height:100%"></canvas>
      </div>
      <div class="text-xs font-mono opacity-30 mt-2">
        Source: <a href="https://stat.ripe.net" target="_blank" rel="noopener" class="hover:opacity-60 underline">RIPEstat</a>
        · <a href="https://ioda.inetintel.cc.gatech.edu" target="_blank" rel="noopener" class="hover:opacity-60 underline">IODA (Georgia Tech)</a>
        · {outages.length} total outage events recorded
      </div>
    </div>

    <!-- ── Status Change Log ────────────────────────────────────────────────── -->
    <div>
      <div class="flex flex-wrap items-center justify-between gap-3 mb-1">
        <h2 class="font-headline text-xl">Status Change Log</h2>
        <div class="flex gap-2">
          <button id="log-dl-csv"
                  class="font-mono text-xs px-3 py-1.5 rounded border border-white/10 hover:border-white/30 transition-colors opacity-60 hover:opacity-100">
            ↓ CSV
          </button>
          <button id="log-dl-json"
                  class="font-mono text-xs px-3 py-1.5 rounded border border-white/10 hover:border-white/30 transition-colors opacity-60 hover:opacity-100">
            { } JSON
          </button>
        </div>
      </div>
      <p class="text-sm opacity-50 mb-4">Offline and recovery events detected from BGP route collector data, newest first.</p>

      <div class="flex gap-1 mb-4">
        {(['1d','3d','7d'] as const).map(w => (
          <button class="log-win-btn font-mono text-xs px-3 py-1 rounded border border-white/10 hover:border-white/30 transition-colors"
                  data-win={w}>
            {w === '1d' ? '24 hours' : w === '3d' ? '3 days' : '7 days'}
          </button>
        ))}
      </div>

      <div id="log-count" class="font-mono text-xs opacity-40 mb-2"></div>

      <div class="border border-white/10 rounded-lg overflow-hidden">
        <div class="overflow-x-auto overflow-y-auto" style="max-height:460px">
          <table class="w-full text-xs font-mono" id="log-table">
            <thead class="sticky top-0 bg-[#08090a] z-10">
              <tr class="border-b border-white/10">
                <th class="py-2 pl-3 pr-3 text-left opacity-50 text-[10px] uppercase tracking-widest w-8">#</th>
                <th class="py-2 pr-3 text-left opacity-50 text-[10px] uppercase tracking-widest whitespace-nowrap">Date / Time (UTC)</th>
                <th class="py-2 pr-3 text-left opacity-50 text-[10px] uppercase tracking-widest">Network</th>
                <th class="py-2 pr-3 text-left opacity-50 text-[10px] uppercase tracking-widest">ASN</th>
                <th class="py-2 pr-3 text-left opacity-50 text-[10px] uppercase tracking-widest">Event</th>
                <th class="py-2 pr-3 text-right opacity-50 text-[10px] uppercase tracking-widest whitespace-nowrap">Outage duration</th>
              </tr>
            </thead>
            <tbody id="log-tbody">
              <!-- Rendered by JS -->
            </tbody>
          </table>
        </div>
      </div>
      <p class="text-xs font-mono opacity-30 mt-2">
        Only showing offline (BGP withdrawn) and recovery events. Intermediate flaps filtered out.
      </p>
    </div>

    <!-- ── All Myanmar Networks ─────────────────────────────────────────────── -->
    <div>
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <h2 class="font-headline text-xl">All Myanmar Networks</h2>
        <div class="flex gap-2">
          <a href="/api/bgp/export.csv"
             class="font-mono text-xs px-3 py-1.5 rounded border border-white/10 hover:border-white/30 transition-colors opacity-60 hover:opacity-100">
            ↓ CSV
          </a>
          <a href="/api/bgp/status.json" target="_blank" rel="noopener"
             class="font-mono text-xs px-3 py-1.5 rounded border border-white/10 hover:border-white/30 transition-colors opacity-60 hover:opacity-100">
            { } JSON
          </a>
        </div>
      </div>

      <!-- Controls bar -->
      <div class="flex flex-wrap gap-2 mb-3 items-center">
        <!-- Search -->
        <input id="net-search" type="search" placeholder="Search network…"
               class="font-mono text-xs px-3 py-1.5 rounded border border-white/10 bg-white/5 focus:outline-none focus:border-white/30 w-44" />

        <!-- Status filter -->
        <select id="net-status-filter"
                class="font-mono text-xs px-3 py-1.5 rounded border border-white/10 bg-[#08090a] focus:outline-none focus:border-white/30">
          <option value="ALL">All statuses</option>
          <option value="DOWN">🔴 DOWN</option>
          <option value="RECOVERING">🟡 RECOVERING</option>
          <option value="UP">🟢 UP</option>
          <option value="OFF">⬛ OFF</option>
        </select>

        <!-- Type filter -->
        <select id="net-type-filter"
                class="font-mono text-xs px-3 py-1.5 rounded border border-white/10 bg-[#08090a] focus:outline-none focus:border-white/30">
          <option value="ALL">All types</option>
          <option value="MNO">MNO</option>
          <option value="IGW">IGW</option>
          <option value="IXP">IXP</option>
          <option value="ISP">ISP</option>
        </select>

        <!-- Column toggle -->
        <div class="relative" id="col-toggle-wrapper">
          <button id="col-toggle-btn"
                  class="font-mono text-xs px-3 py-1.5 rounded border border-white/10 hover:border-white/30 transition-colors">
            Columns ▾
          </button>
          <div id="col-toggle-menu"
               class="absolute left-0 top-full mt-1 hidden z-20 bg-[#0f1011] border border-white/10 rounded-lg p-3 space-y-1.5 min-w-[160px] shadow-xl">
            <label class="flex items-center gap-2 font-mono text-xs cursor-pointer">
              <input type="checkbox" data-col="description" checked class="col-checkbox" /> Description
            </label>
            <label class="flex items-center gap-2 font-mono text-xs cursor-pointer">
              <input type="checkbox" data-col="asName" class="col-checkbox" /> AS Name
            </label>
            <label class="flex items-center gap-2 font-mono text-xs cursor-pointer">
              <input type="checkbox" data-col="asn" checked class="col-checkbox" /> ASN
            </label>
            <label class="flex items-center gap-2 font-mono text-xs cursor-pointer">
              <input type="checkbox" data-col="type" checked class="col-checkbox" /> Type
            </label>
            <label class="flex items-center gap-2 font-mono text-xs cursor-pointer">
              <input type="checkbox" data-col="status" checked class="col-checkbox" /> Status
            </label>
            <label class="flex items-center gap-2 font-mono text-xs cursor-pointer">
              <input type="checkbox" data-col="visibility" checked class="col-checkbox" /> Visibility
            </label>
            <label class="flex items-center gap-2 font-mono text-xs cursor-pointer">
              <input type="checkbox" data-col="since" checked class="col-checkbox" /> Since
            </label>
          </div>
        </div>

        <!-- Spacer -->
        <div class="flex-1"></div>

        <!-- Page size -->
        <div class="flex items-center gap-2 font-mono text-xs opacity-60">
          Rows:
          <select id="net-page-size"
                  class="px-2 py-1 rounded border border-white/10 bg-[#08090a] focus:outline-none">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="100">100</option>
            <option value="all">All</option>
          </select>
        </div>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="net-table">
          <thead>
            <tr class="border-b border-white/10 text-left">
              <th class="pb-2 pr-4 font-mono text-xs opacity-40 uppercase tracking-widest sortable"
                  data-col="description" data-sort="description"
                  data-tip="Human-readable commercial name. For ISPs without a known brand, falls back to WHOIS name.">
                Description <span class="opacity-50">ⓘ</span><span class="sort-arrow"></span>
              </th>
              <th class="pb-2 pr-4 font-mono text-xs opacity-40 uppercase tracking-widest sortable hidden"
                  data-col="asName" data-sort="asName"
                  data-tip="Raw WHOIS name from the BGP routing registry (APNIC).">
                AS Name <span class="opacity-50">ⓘ</span><span class="sort-arrow"></span>
              </th>
              <th class="pb-2 pr-4 font-mono text-xs opacity-40 uppercase tracking-widest sortable"
                  data-col="asn" data-sort="asn"
                  data-tip="Autonomous System Number — unique identifier in the global BGP routing table.">
                ASN <span class="opacity-50">ⓘ</span><span class="sort-arrow"></span>
              </th>
              <th class="pb-2 pr-3 font-mono text-xs opacity-40 uppercase tracking-widest sortable"
                  data-col="type" data-sort="type"
                  data-tip="MNO = Mobile Network Operator · IGW = International Gateway · IXP = Internet Exchange Point · ISP = Domestic ISP">
                Type <span class="opacity-50">ⓘ</span><span class="sort-arrow"></span>
              </th>
              <th class="pb-2 pr-4 font-mono text-xs opacity-40 uppercase tracking-widest text-center sortable"
                  data-col="status" data-sort="statusPriority"
                  data-tip="Current BGP routing status. DOWN = routes withdrawn from global table. RECOVERING = routes re-announced within the last hour.">
                Status <span class="opacity-50">ⓘ</span><span class="sort-arrow"></span>
              </th>
              <th class="pb-2 pr-4 font-mono text-xs opacity-40 uppercase tracking-widest text-right sortable"
                  data-col="visibility" data-sort="visibility"
                  data-tip="Percentage of RIPE route collectors worldwide that can see this network's routes. 100% = fully visible. 0% = withdrawn/invisible.">
                Visibility <span class="opacity-50">ⓘ</span><span class="sort-arrow"></span>
              </th>
              <th class="pb-2 pr-4 font-mono text-xs opacity-40 uppercase tracking-widest text-right sortable"
                  data-col="since" data-sort="since"
                  data-tip="Time elapsed since the current status began.">
                Since <span class="opacity-50">ⓘ</span><span class="sort-arrow"></span>
              </th>
              <th class="pb-2 font-mono text-xs opacity-40 uppercase tracking-widest"></th>
            </tr>
          </thead>
          <tbody id="net-tbody">
            <!-- Rendered by JS -->
          </tbody>
        </table>
      </div>

      <!-- Pagination bar -->
      <div class="flex items-center justify-between mt-3 font-mono text-xs opacity-50">
        <span id="net-pagination-info"></span>
        <div class="flex gap-1">
          <button id="net-prev" class="px-3 py-1 rounded border border-white/10 hover:border-white/30 disabled:opacity-20">← Prev</button>
          <button id="net-next" class="px-3 py-1 rounded border border-white/10 hover:border-white/30 disabled:opacity-20">Next →</button>
        </div>
      </div>
    </div>

    <!-- Methodology -->
    <div class="border-t border-white/10 pt-10 max-w-3xl">
      <h2 class="font-headline text-xl mb-6">Measurement Methodology</h2>
      <div class="space-y-5 text-sm leading-relaxed opacity-80">

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-accent)] uppercase tracking-widest mb-2">BGP Routing as a Shutdown Signal</h3>
          <p>
            The Border Gateway Protocol (BGP) is the routing infrastructure of the internet — the
            system by which autonomous systems announce the reachability of their IP address blocks
            to the global routing table. When a Myanmar ISP is ordered offline, its administrators
            withdraw its BGP prefix announcements. This withdrawal propagates through the global
            routing table within minutes, making the network unreachable from outside Myanmar and
            vice versa. BGP analysis is the fastest available technical signal for detecting
            deliberate network disconnections: withdrawals are typically observable 2–15 minutes
            after an order is executed, well before independent reporting or network monitoring
            alerts. It is the methodology used by
            <a href="https://ioda.inetintel.cc.gatech.edu" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">IODA at Georgia Tech</a>,
            <a href="https://netblocks.org" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">NetBlocks</a>,
            and <a href="https://ooni.org" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">OONI</a>
            for corroborating application-layer interference with routing-layer evidence.
            See also our <a href="/observatory/shutdown-tracker/" class="underline hover:opacity-100">Shutdown Tracker</a>
            for the application-layer view.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-accent)] uppercase tracking-widest mb-2">Route Collector Network</h3>
          <p>
            BGP data is sourced from
            <a href="https://stat.ripe.net" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">RIPEstat (RIPE NCC)</a>,
            which aggregates routing table snapshots from 800+ globally distributed route collectors
            maintained by academic institutions, internet exchange points, and network operators.
            Each collector independently observes the global routing table from its vantage point.
            A prefix withdrawal is confirmed only when a threshold of multiple geographically
            distributed collectors no longer observe the route — reducing false positives from
            local peering changes, collector failures, or transient route flapping.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-accent)] uppercase tracking-widest mb-2">Visibility Percentage</h3>
          <p>
            Each ASN is assigned a visibility percentage representing the share of route collectors
            that currently observe at least one active prefix for that autonomous system, relative
            to that ASN's historical maximum. 100% indicates full global reachability. Drops below
            50% are classified as significant partial outages; drops to 0% indicate complete
            disconnection from the global routing table.
            <strong>RECOVERING</strong> status is applied when visibility has returned from a DOWN
            state within the past 60 minutes — the network is back online but still being watched
            for stability.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-accent)] uppercase tracking-widest mb-2">Status Classification</h3>
          <p>
            <strong>DOWN</strong> — visibility dropped to ≤10% of historical baseline, sustained
            for more than 5 minutes. <strong>RECOVERING</strong> — visibility returned from DOWN
            within the past 60 minutes. <strong>UP</strong> — visibility stable above baseline for
            more than 1 hour. <strong>OFF</strong> — no BGP presence detected for more than 7 days;
            network dark, not temporarily disrupted. Outage events under 5 minutes are flagged as
            probable route flapping (BGP instability caused by hardware faults or misconfiguration)
            rather than deliberate shutdown, consistent with the filtering methodology used by
            <a href="https://ioda.inetintel.cc.gatech.edu" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">IODA</a>
            and
            <a href="https://www.caida.org" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">CAIDA</a>.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-accent)] uppercase tracking-widest mb-2">Network Type Classification (MNO / ISP / IGW / IXP)</h3>
          <p>
            Each autonomous system is classified by network function based on observed BGP peering
            behaviour, prefix announcements, and routing relationships — not on Myanmar government
            registry filings or operator self-declaration. Mobile Network Operators (MNOs) are
            identified by large consumer-facing prefix blocks with predominantly stub AS topology.
            International Gateway operators (IGWs) are identified by transit relationships with
            upstream international carriers and the presence of upstream BGP sessions crossing
            Myanmar's international borders. Internet Exchange Points (IXPs) are identified by
            shared peering fabrics with multiple local ASNs as peers. ISPs are identified by
            downstream customer cone relationships and absence of mobile-specific prefix patterns.
            This classification reflects observed routing reality and may differ from official
            Myanmar government licensing categories or operator marketing designations — a
            distinction that becomes significant when licensing structures and operational
            infrastructure diverge, as has been documented following forced ownership transfers
            since 2021.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-accent)] uppercase tracking-widest mb-2">Monitored ASNs & Cross-Validation</h3>
          <p>
            We track all autonomous systems registered to Myanmar-based operators, including mobile
            network operators (MPT AS9988, Mytel AS136168, Ooredoo Myanmar AS132748, Atom Myanmar
            AS132167), international gateway providers, internet exchange points, and
            government-adjacent infrastructure. BGP withdrawal events are cross-referenced against
            <a href="/observatory/shutdown-tracker/" class="underline hover:opacity-100">OONI anomaly spikes</a>
            and Cloudflare Radar traffic drops; deliberate shutdown classification is applied only
            when routing withdrawal persists and is corroborated by independent application-layer
            interference data. Confirmed shutdown events are further validated against contemporaneous
            reporting from
            <a href="https://english.dvb.no" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">DVB</a>,
            <a href="https://www.irrawaddy.com" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">The Irrawaddy</a>,
            and international newswires. The full list of monitored networks is available via the
            JSON export above.
          </p>
        </div>

      </div>
    </div>

  </div><!-- /space-y-12 -->
</Observatory>

<!-- ── Client-side JS ──────────────────────────────────────────────────────── -->
<script>
  // Load Chart.js from CDN
  const s = document.createElement('script')
  s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js'
  s.onload = initChart
  document.head.appendChild(s)

  const chartData = JSON.parse(document.getElementById('chart-data')!.textContent!)
  const lbData    = JSON.parse(document.getElementById('lb-data')!.textContent!)
  const tableData = JSON.parse(document.getElementById('table-data')!.textContent!)

  // ── Toggle helpers ──────────────────────────────────────────────────────────

  function setActive(group: string, value: string) {
    document.querySelectorAll(`.${group}`).forEach(btn => {
      const el = btn as HTMLElement
      const active = el.dataset.win === value || el.dataset.filter === value
      el.style.background  = active ? 'rgba(0,212,200,0.12)' : ''
      el.style.borderColor = active ? 'rgba(0,212,200,0.4)'  : ''
      el.style.color       = active ? '#7170ff'              : ''
    })
  }

  // ── Chart ───────────────────────────────────────────────────────────────────

  let chart: any = null
  let chartWin   = '1w'
  let chartFlap  = 'all'

  function initChart() { renderChart() }

  function renderChart() {
    const d   = (chartData as any)[chartFlap][chartWin]
    const ctx = (document.getElementById('outage-chart') as HTMLCanvasElement)?.getContext('2d')
    if (!ctx) return
    if (chart) chart.destroy()

    const accent = '#E24B4A'
    const empty  = 'rgba(255,255,255,0.07)'

    chart = new (window as any).Chart(ctx, {
      type: 'bar',
      data: {
        labels: d.labels,
        datasets: [{ data: d.data,
          backgroundColor: d.data.map((v: number) => v > 0 ? accent : empty),
          borderRadius: 3, borderSkipped: false }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: (c: any) => `${c.parsed.y} outage event${c.parsed.y !== 1 ? 's' : ''}` } }
        },
        scales: {
          x: { ticks: { color: '#64748b', font: { size: 10 }, maxRotation: 45, autoSkip: false },
               grid:  { color: 'rgba(255,255,255,0.04)' } },
          y: { beginAtZero: true,
               ticks: { color: '#64748b', font: { size: 10 }, stepSize: 1, precision: 0 },
               grid:  { color: 'rgba(255,255,255,0.04)' } }
        }
      }
    })

    const sub = document.getElementById('chart-subtitle')
    if (sub) sub.textContent = `${d.total} total events · granularity: per ${d.granularity}`
  }

  document.querySelectorAll('.chart-win-btn').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLElement) {
      chartWin = this.dataset.win!; setActive('chart-win-btn', chartWin); renderChart()
    })
  })
  document.querySelectorAll('.chart-flap-btn').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLElement) {
      chartFlap = this.dataset.filter!; setActive('chart-flap-btn', chartFlap); renderChart()
    })
  })

  // ── Leaderboard ─────────────────────────────────────────────────────────────

  let lbWin  = '7d'
  let lbFlap = 'all'

  const TYPE_STYLE: Record<string, {bg: string; color: string}> = {
    MNO: { bg: 'rgba(239,68,68,0.15)',   color: '#fca5a5' },
    IGW: { bg: 'rgba(245,158,11,0.15)',  color: '#fcd34d' },
    IXP: { bg: 'rgba(59,130,246,0.15)',  color: '#93c5fd' },
    ISP: { bg: 'rgba(148,163,184,0.10)', color: '#94a3b8' },
  }

  function renderLeaderboard() {
    const entries   = (lbData as any)[lbFlap][lbWin]
    const container = document.getElementById('leaderboard-rows')!
    if (!entries.length) {
      container.innerHTML = '<p class="text-sm font-mono opacity-40">No outage events in this window.</p>'
      return
    }
    const max = entries[0]?.outage_count || 1
    container.innerHTML = entries.map((e: any) => {
      const pct = Math.round((e.outage_count / max) * 100)
      const bar = pct > 66 ? '#E24B4A' : pct > 33 ? '#f59e0b' : '#22c55e'
      const ts  = TYPE_STYLE[e.type] ?? TYPE_STYLE.ISP
      const h   = Math.floor(e.total_downtime_minutes / 60)
      const m   = e.total_downtime_minutes % 60
      const dt  = h > 0 ? `${h}h ${m}m` : `${m}m`
      return `<div class="flex items-center gap-3 py-2 px-3 rounded hover:bg-white/3 group">
        <span class="font-mono text-xs opacity-40 w-5 text-right shrink-0">${e.rank}</span>
        <span class="font-mono text-xs px-1.5 py-0.5 rounded shrink-0"
              style="background:${ts.bg};color:${ts.color}">${e.type}</span>
        <span class="text-sm truncate flex-1 min-w-0" title="${e.name}">${e.name}
          <span class="font-mono text-xs opacity-40 ml-1">${e.asn}</span>
        </span>
        <div class="w-28 shrink-0">
          <div class="h-2 rounded-full bg-white/5">
            <div class="h-2 rounded-full" style="width:${pct}%;background:${bar}"></div>
          </div>
        </div>
        <span class="font-mono text-xs w-6 text-right shrink-0" style="color:${bar}">${e.outage_count}</span>
        <span class="font-mono text-xs opacity-40 w-14 text-right shrink-0">${dt}</span>
        <a href="/observatory/bgp/${e.asn}" class="font-mono text-xs opacity-0 group-hover:opacity-40 hover:!opacity-100 underline shrink-0">→</a>
      </div>`
    }).join('')
  }

  document.querySelectorAll('.lb-win-btn').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLElement) {
      lbWin = this.dataset.win!; setActive('lb-win-btn', lbWin); renderLeaderboard()
    })
  })
  document.querySelectorAll('.lb-flap-btn').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLElement) {
      lbFlap = this.dataset.filter!; setActive('lb-flap-btn', lbFlap); renderLeaderboard()
    })
  })

  // ── Network table ────────────────────────────────────────────────────────────

  interface Row {
    asn: string; asName: string; description: string
    type: string; status: string; statusLabel: string
    statusPriority: number; statusColor: string
    visibility: number | null; since: string; off: boolean
  }

  const TYPE_BADGE: Record<string, {bg: string; color: string}> = TYPE_STYLE

  let ntSearch    = ''
  let ntStatus    = 'ALL'
  let ntType      = 'ALL'
  let ntPage      = 1
  let ntPageSize: number | 'all' = 25
  let ntSortCol   = 'statusPriority'
  let ntSortDir   = 1   // 1 = asc, -1 = desc
  let hiddenCols  = new Set<string>(['asName'])

  function formatSince(since: string, off: boolean): string {
    if (!since) return '—'
    const diffMs = Date.now() - new Date(since).getTime()
    const diffH  = Math.floor(diffMs / 3600000)
    const diffM  = Math.floor((diffMs % 3600000) / 60000)
    const diffD  = Math.floor(diffH / 24)
    if (diffD > 1)  return `${diffD}d ago`
    if (diffH > 0)  return `${diffH}h ${diffM}m ago`
    return `${diffM}m ago`
  }

  function getVal(row: Row, col: string): any {
    if (col === 'statusPriority') return row.statusPriority
    if (col === 'description')    return row.description.toLowerCase()
    if (col === 'asName')         return row.asName.toLowerCase()
    if (col === 'asn')            return parseInt(row.asn.replace('AS',''))
    if (col === 'type') {
      const order: Record<string,number> = { MNO:0, IGW:1, IXP:2, ISP:3 }
      return order[row.type] ?? 9
    }
    if (col === 'visibility') return row.visibility ?? -1
    if (col === 'since')      return row.since || ''
    return ''
  }

  function filterRows(): Row[] {
    return (tableData as Row[]).filter(r => {
      if (ntStatus !== 'ALL' && r.statusLabel !== ntStatus) return false
      if (ntType   !== 'ALL' && r.type         !== ntType)  return false
      if (ntSearch) {
        const q = ntSearch.toLowerCase()
        if (!r.description.toLowerCase().includes(q) &&
            !r.asName.toLowerCase().includes(q) &&
            !r.asn.toLowerCase().includes(q)) return false
      }
      return true
    })
  }

  function sortRows(rows: Row[]): Row[] {
    return [...rows].sort((a, b) => {
      const av = getVal(a, ntSortCol)
      const bv = getVal(b, ntSortCol)
      if (av < bv) return -ntSortDir
      if (av > bv) return  ntSortDir
      return 0
    })
  }

  function renderTable() {
    const filtered  = filterRows()
    const sorted    = sortRows(filtered)
    const total     = sorted.length
    const pageSize  = ntPageSize === 'all' ? total : ntPageSize
    const totalPages = Math.max(1, Math.ceil(total / pageSize))
    if (ntPage > totalPages) ntPage = totalPages
    const start  = (ntPage - 1) * pageSize
    const slice  = sorted.slice(start, start + pageSize)

    const tbody = document.getElementById('net-tbody')!
    tbody.innerHTML = slice.map(r => {
      const badge = TYPE_BADGE[r.type] ?? TYPE_BADGE.ISP
      const pulseClass = r.status === 'RED' && !r.off ? 'animate-pulse' : ''
      const rowClass   = r.status === 'RED' && !r.off ? 'bg-[#ef4444]/5' : r.off ? 'opacity-35' : ''
      const cols: string[] = []

      if (!hiddenCols.has('description'))
        cols.push(`<td class="py-2 pr-4 truncate max-w-[200px]" title="${esc(r.description)}">${esc(r.description)}</td>`)
      if (!hiddenCols.has('asName'))
        cols.push(`<td class="py-2 pr-4 font-mono text-xs opacity-50 truncate max-w-[180px]" title="${esc(r.asName)}">${esc(r.asName)}</td>`)
      if (!hiddenCols.has('asn'))
        cols.push(`<td class="py-2 pr-4 font-mono text-xs opacity-60">${r.asn}</td>`)
      if (!hiddenCols.has('type'))
        cols.push(`<td class="py-2 pr-3">
          <span class="inline-block text-xs font-mono px-1.5 py-0.5 rounded"
                style="background:${badge.bg};color:${badge.color}">${r.type}</span>
        </td>`)
      if (!hiddenCols.has('status'))
        cols.push(`<td class="py-2 pr-4 text-center">
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block w-2 h-2 rounded-full ${pulseClass}"
                  style="background:${r.statusColor}"></span>
            <span class="font-mono text-xs" style="color:${r.statusColor}">${r.statusLabel}</span>
          </span>
        </td>`)
      if (!hiddenCols.has('visibility'))
        cols.push(`<td class="py-2 pr-4 text-right font-mono text-xs">${r.visibility !== null ? r.visibility + '%' : '—'}</td>`)
      if (!hiddenCols.has('since'))
        cols.push(`<td class="py-2 pr-4 text-right font-mono text-xs opacity-50">${formatSince(r.since, r.off)}</td>`)

      cols.push(`<td class="py-2 text-right">
        <a href="/observatory/bgp/${r.asn}" class="font-mono text-xs opacity-30 hover:opacity-100 hover:text-[#7170ff] underline">→</a>
      </td>`)

      return `<tr class="border-b border-white/5 hover:bg-white/2 ${rowClass}">${cols.join('')}</tr>`
    }).join('')

    // Pagination info
    const info = document.getElementById('net-pagination-info')!
    info.textContent = total === 0
      ? 'No results'
      : `Showing ${start + 1}–${Math.min(start + pageSize, total)} of ${total}`

    const prevBtn = document.getElementById('net-prev') as HTMLButtonElement
    const nextBtn = document.getElementById('net-next') as HTMLButtonElement
    prevBtn.disabled = ntPage <= 1
    nextBtn.disabled = ntPage >= totalPages

    // Update column header sort indicators
    document.querySelectorAll<HTMLElement>('#net-table th[data-sort]').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc')
      if (th.dataset.sort === ntSortCol) {
        th.classList.add(ntSortDir === 1 ? 'sort-asc' : 'sort-desc')
      }
    })

    // Sync column visibility on headers
    document.querySelectorAll<HTMLElement>('#net-table th[data-col]').forEach(th => {
      const col = th.dataset.col!
      th.style.display = hiddenCols.has(col) ? 'none' : ''
    })
  }

  function esc(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')
  }

  // Wire up controls
  document.getElementById('net-search')!.addEventListener('input', function(this: HTMLInputElement) {
    ntSearch = this.value; ntPage = 1; renderTable()
  })
  document.getElementById('net-status-filter')!.addEventListener('change', function(this: HTMLSelectElement) {
    ntStatus = this.value; ntPage = 1; renderTable()
  })
  document.getElementById('net-type-filter')!.addEventListener('change', function(this: HTMLSelectElement) {
    ntType = this.value; ntPage = 1; renderTable()
  })
  document.getElementById('net-page-size')!.addEventListener('change', function(this: HTMLSelectElement) {
    ntPageSize = this.value === 'all' ? 'all' : parseInt(this.value)
    ntPage = 1; renderTable()
  })
  document.getElementById('net-prev')!.addEventListener('click', () => { ntPage--; renderTable() })
  document.getElementById('net-next')!.addEventListener('click', () => { ntPage++; renderTable() })

  // Sort on header click
  document.querySelectorAll<HTMLElement>('#net-table th[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.sort!
      if (ntSortCol === col) ntSortDir = -ntSortDir
      else { ntSortCol = col; ntSortDir = 1 }
      ntPage = 1; renderTable()
    })
  })

  // Column toggle dropdown
  const colBtn  = document.getElementById('col-toggle-btn')!
  const colMenu = document.getElementById('col-toggle-menu')!
  colBtn.addEventListener('click', e => {
    e.stopPropagation()
    colMenu.classList.toggle('hidden')
  })
  document.addEventListener('click', () => colMenu.classList.add('hidden'))
  colMenu.addEventListener('click', e => e.stopPropagation())

  document.querySelectorAll<HTMLInputElement>('.col-checkbox').forEach(cb => {
    cb.addEventListener('change', function() {
      if (this.checked) hiddenCols.delete(this.dataset.col!)
      else              hiddenCols.add(this.dataset.col!)
      renderTable()
    })
  })

  // ── Status change log ───────────────────────────────────────────────────────

  const allEventsRaw: any[] = JSON.parse(document.getElementById('events-data')!.textContent!)

  // Only show offline (→RED) and recovery (RED→GREEN or RED→YELLOW) events
  const logEvents = allEventsRaw.filter(ev =>
    ev.to === 'RED' || (ev.from === 'RED' && (ev.to === 'GREEN' || ev.to === 'YELLOW'))
  )

  let logWin = '7d'

  function logCutoff(): number {
    const days = logWin === '1d' ? 1 : logWin === '3d' ? 3 : 7
    return Date.now() - days * 86400000
  }

  function fmtLogDowntime(min: number | null): string {
    if (min === null) return '—'
    const h = Math.floor(min / 60); const m = min % 60
    return h > 0 ? `${h}h ${m}m` : `${m}m`
  }

  function renderLog() {
    const cutoff  = logCutoff()
    const visible = logEvents.filter(ev => new Date(ev.timestamp).getTime() >= cutoff)

    const countEl = document.getElementById('log-count')!
    countEl.textContent = `${visible.length} event${visible.length !== 1 ? 's' : ''} in this window`

    const tbody = document.getElementById('log-tbody')!
    if (visible.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="py-4 pl-3 opacity-40">No events in this window.</td></tr>'
      return
    }

    tbody.innerHTML = visible.map((ev, i) => {
      const isDown     = ev.to === 'RED'
      const isBack     = ev.from === 'RED' && ev.to === 'GREEN'
      const isPartial  = ev.from === 'RED' && ev.to === 'YELLOW'
      const color      = isDown ? '#ef4444' : isBack ? '#22c55e' : '#f59e0b'
      const icon       = isDown ? '🔴' : isBack ? '🟢' : '🟡'
      const verb       = isDown ? 'went offline' : isBack ? 'back online' : 'partially recovering'
      const rowBg      = isDown ? 'background:rgba(239,68,68,0.05)' : isBack ? 'background:rgba(34,197,94,0.03)' : ''
      const ts         = ev.timestamp.replace('T', ' ').slice(0, 16)
      const dt         = (isBack || isPartial) ? fmtLogDowntime(ev.downtime_minutes) : ''

      return `<tr class="border-b border-white/5 hover:bg-white/2" style="${rowBg}">
        <td class="py-1.5 pl-3 pr-2 opacity-30 text-right w-8">${i + 1}</td>
        <td class="py-1.5 pr-3 opacity-50 whitespace-nowrap">${ts}</td>
        <td class="py-1.5 pr-3 max-w-[200px] truncate">
          <a href="/observatory/bgp/${esc(ev.asn)}" class="hover:underline opacity-80" title="${esc(ev.description)}">${esc(ev.description)}</a>
        </td>
        <td class="py-1.5 pr-3 opacity-40 text-[10px]">${esc(ev.asn)}</td>
        <td class="py-1.5 pr-3 whitespace-nowrap" style="color:${color}">${icon} ${verb}</td>
        <td class="py-1.5 pr-3 text-right opacity-50 whitespace-nowrap">
          ${dt ? `<span class="px-1.5 py-0.5 rounded text-[10px]" style="background:rgba(255,255,255,0.05)">${dt}</span>` : '<span class="opacity-20">—</span>'}
        </td>
      </tr>`
    }).join('')
  }

  function logToCSV(): string {
    const cutoff  = logCutoff()
    const visible = logEvents.filter(ev => new Date(ev.timestamp).getTime() >= cutoff)
    const rows = [['#','datetime_utc','network','asn','event','outage_duration_minutes']]
    visible.forEach((ev, i) => {
      const isDown    = ev.to === 'RED'
      const isBack    = ev.from === 'RED' && (ev.to === 'GREEN' || ev.to === 'YELLOW')
      const verb      = isDown ? 'went_offline' : isBack ? 'back_online' : ev.to.toLowerCase()
      const dt        = (isBack && ev.downtime_minutes !== null) ? ev.downtime_minutes : ''
      rows.push([String(i+1), ev.timestamp.slice(0,16), `"${ev.description}"`, ev.asn, verb, String(dt)])
    })
    return rows.map(r => r.join(',')).join('\n')
  }

  function download(content: string, filename: string, mime: string) {
    const a = document.createElement('a')
    a.href = URL.createObjectURL(new Blob([content], { type: mime }))
    a.download = filename
    a.click()
    URL.revokeObjectURL(a.href)
  }

  document.querySelectorAll('.log-win-btn').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLElement) {
      logWin = this.dataset.win!; setActive('log-win-btn', logWin); renderLog()
    })
  })

  document.getElementById('log-dl-csv')!.addEventListener('click', () => {
    download(logToCSV(), `myanmar-network-events-${logWin}.csv`, 'text/csv')
  })
  document.getElementById('log-dl-json')!.addEventListener('click', () => {
    const cutoff  = logCutoff()
    const visible = logEvents.filter(ev => new Date(ev.timestamp).getTime() >= cutoff)
    download(JSON.stringify(visible, null, 2), `myanmar-network-events-${logWin}.json`, 'application/json')
  })

  // ── Initial render ──────────────────────────────────────────────────────────

  setActive('chart-win-btn',  '1w')
  setActive('chart-flap-btn', 'all')
  setActive('lb-win-btn',     '7d')
  setActive('lb-flap-btn',    'all')
  setActive('log-win-btn',    '7d')
  renderLeaderboard()
  renderTable()
  renderLog()
  // Chart renders in s.onload after Chart.js CDN loads
</script>
