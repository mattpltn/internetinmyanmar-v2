---
import Observatory from '../../layouts/Observatory.astro'
import CfRadarBanner from '../../components/CfRadarBanner.astro'
import stats from '../../content/observatory/stats.json'
import asnStatusRaw from '../../data/asn-status.json'
import bgpOutagesRaw from '../../data/bgp-outages.json'
import cfOutages from '../../data/cf-radar-outages.json'
import LiveSignalChart from '../../components/charts/LiveSignalChart.astro'
import metricsSnapshotRaw from '../../../public/data/metrics_snapshot.json'

export const prerender = true

const asnStatus: Record<string, any> = asnStatusRaw as any
const bgpOutages: any[] = bgpOutagesRaw as any

const bgpTotal = Object.keys(asnStatus).length
const bgpDown  = Object.values(asnStatus).filter((a: any) => a.status === 'RED').length

const liveMetrics: Record<string, any> = metricsSnapshotRaw as any

const activeShutdowns      = liveMetrics.active_shutdowns      ?? stats.activeShutdowns
const confirmedBlocked     = liveMetrics.confirmed_blocked_sites ?? stats.blockedSites
const daysSinceMajorOutage = liveMetrics.days_since_major_outage ?? stats.daysSinceLastMajorOutage
const ooniRate30d          = liveMetrics.ooni_anomaly_rate_30d  ?? null
const bgpDownLive          = liveMetrics.bgp_networks_down_now  ?? bgpDown
---
<Observatory
  title="Internet Observatory — Myanmar"
  seoTitle="Myanmar Internet Observatory | Censorship Data"
  metaDescription="Real-time tracking of internet shutdowns, blocked sites, and connectivity anomalies in Myanmar. Powered by OONI data."
  lastUpdated={stats.lastUpdated}
>
  <div class="max-w-7xl mx-auto px-4 py-12">

    <!-- Stats grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="border border-white/10 rounded-lg p-6 text-center">
        <div class="font-mono text-3xl font-bold text-[color:var(--color-danger)] mb-1">
          {activeShutdowns}
        </div>
        <div class="text-sm opacity-60">Active Shutdowns</div>
      </div>
      <div class="border border-white/10 rounded-lg p-6 text-center">
        <div class="font-mono text-3xl font-bold text-[color:var(--color-warning)] mb-1">
          {confirmedBlocked}
        </div>
        <div class="text-sm opacity-60">Confirmed Blocked Sites</div>
      </div>
      <div class="border border-white/10 rounded-lg p-6 text-center">
        <div class="font-mono text-3xl font-bold text-[color:var(--color-accent)] mb-1">
          {ooniRate30d != null ? `${ooniRate30d}%` : daysSinceMajorOutage}
        </div>
        <div class="text-sm opacity-60">{ooniRate30d != null ? 'OONI Anomaly Rate 30d' : 'Days Since Major Outage'}</div>
      </div>
      <div class="border border-white/10 rounded-lg p-6 text-center">
        <div class="font-mono text-3xl font-bold text-white mb-1">MM</div>
        <div class="text-sm opacity-60">Country Code</div>
      </div>
    </div>

    <CfRadarBanner
      activeOutages={cfOutages.activeOutages}
      lastUpdated={cfOutages.lastUpdated}
    />

    {stats.note && (
      <div class="border-l-4 border-[color:var(--color-warning)] pl-4 mb-12 opacity-80 text-sm">
        {stats.note}
      </div>
    )}

    <!-- Current conditions: 30-day live signal -->
    <LiveSignalChart />

    <!-- Sub-sections -->
    <div class="grid md:grid-cols-2 gap-6">
      <a href="/observatory/shutdown-tracker/" class="border border-white/10 rounded-lg p-6 hover:border-[color:var(--color-accent)] transition-colors group">
        <div class="font-mono text-xs text-[color:var(--color-danger)] mb-2 uppercase tracking-widest">Live tracker</div>
        <h2 class="font-headline text-2xl mb-2 group-hover:text-[color:var(--color-accent)] transition-colors">Shutdown Tracker</h2>
        <p class="opacity-60 text-sm">Timeline of internet shutdowns and service disruptions documented by OONI and independent monitors.</p>
      </a>
      <a href="/observatory/blocked-sites/" class="border border-white/10 rounded-lg p-6 hover:border-[color:var(--color-accent)] transition-colors group">
        <div class="font-mono text-xs text-[color:var(--color-warning)] mb-2 uppercase tracking-widest">Censorship database</div>
        <h2 class="font-headline text-2xl mb-2 group-hover:text-[color:var(--color-accent)] transition-colors">Blocked Sites Monitor</h2>
        <p class="opacity-60 text-sm">Confirmed blocked domains across Myanmar ISPs — updated from OONI measurement data.</p>
      </a>
      <a href="/observatory/bgp/" class="border border-white/10 rounded-lg p-6 hover:border-[color:var(--color-accent)] transition-colors group">
        <div class="font-mono text-xs text-[color:var(--color-accent)] mb-2 uppercase tracking-widest">BGP routing</div>
        <h2 class="font-headline text-2xl mb-2 group-hover:text-[color:var(--color-accent)] transition-colors">BGP Network Status</h2>
        <p class="opacity-60 text-sm mb-3">
          Real-time BGP visibility for {bgpTotal > 0 ? bgpTotal : 'all'} Myanmar autonomous systems.
          Detects shutdowns within minutes via 800+ global route collectors.
        </p>
        {bgpDown > 0 && (
          <div class="font-mono text-xs text-[color:var(--color-danger)]">
            ⚠ {bgpDown} network{bgpDown !== 1 ? 's' : ''} currently down
          </div>
        )}
        {bgpDown === 0 && bgpTotal > 0 && (
          <div class="font-mono text-xs" style="color:#22c55e">
            ✓ All networks operational
          </div>
        )}
      </a>
      <a href="/observatory/data/" class="border border-white/10 rounded-lg p-6 hover:border-[color:var(--color-accent)] transition-colors group">
        <div class="font-mono text-xs opacity-50 mb-2 uppercase tracking-widest">Open data</div>
        <h2 class="font-headline text-2xl mb-2 group-hover:text-[color:var(--color-accent)] transition-colors">Dataset Downloads</h2>
        <p class="opacity-60 text-sm">Download the raw datasets — BGP events, OONI timeseries, shutdown records, blocked sites — under CC BY 4.0.</p>
      </a>
    </div>

    <!-- Methodology -->
    <div class="mt-16 border-t border-white/10 pt-10 max-w-3xl">
      <h2 class="font-headline text-xl mb-6">About This Observatory</h2>
      <div class="space-y-5 text-sm leading-relaxed opacity-80">
        <p>
          The Myanmar Internet Observatory integrates four independent measurement layers into a
          unified monitoring system tracking Myanmar's digital environment continuously since the
          February 2021 military coup: application-layer probing via
          <a href="https://ooni.org" target="_blank" rel="noopener" class="underline hover:opacity-100">OONI</a>,
          traffic telemetry via <a href="https://radar.cloudflare.com" target="_blank" rel="noopener" class="underline hover:opacity-100">Cloudflare Radar</a>,
          routing-layer surveillance via BGP analysis, and human-verified shutdown records from
          <a href="https://www.accessnow.org/keepiton/" target="_blank" rel="noopener" class="underline hover:opacity-100">Access Now's STOP Dataset</a>.
        </p>
        <p>
          No single source is treated as sufficient. Network interference in Myanmar manifests
          across layers simultaneously: an ISP ordered offline withdraws BGP routes within minutes,
          OONI probes detect URL-level blocking within hours, Cloudflare Radar traffic drops
          confirm the population-level impact, and Access Now researchers document the event with
          geographic attribution and perpetrator identification. Triangulating these four signals
          distinguishes confirmed shutdown from technical fault, and targeted censorship from
          infrastructure failure — a methodology aligned with
          <a href="https://netblocks.org" target="_blank" rel="noopener" class="underline hover:opacity-100">NetBlocks</a>,
          <a href="https://ioda.inetintel.cc.gatech.edu" target="_blank" rel="noopener" class="underline hover:opacity-100">IODA (Georgia Tech)</a>,
          and the <a href="https://citizenlab.ca" target="_blank" rel="noopener" class="underline hover:opacity-100">Citizen Lab</a>.
        </p>
        <p>
          The <em>30-Day Live Signal</em> chart on this page combines OONI daily anomaly rates
          with Cloudflare Radar daily traffic on a single dual-axis view — the fastest read on
          whether today's connectivity is normal, degraded, or severed. Individual observatory
          sections go deeper: the <a href="/observatory/shutdown-tracker/" class="underline hover:opacity-100">Shutdown Tracker</a> gives
          the full five-year timeline with verified shutdown overlays and a regional map;
          the <a href="/observatory/blocked-sites/" class="underline hover:opacity-100">Blocked Sites Monitor</a> lists
          every domain flagged by OONI with block rate and category breakdown;
          the <a href="/observatory/bgp/" class="underline hover:opacity-100">BGP Network Status</a> page
          shows routing-layer events updated every five minutes.
          Raw datasets are available for download from each section.
        </p>
        <p>
          All source data is attributed to its originating institution and published under open
          licences (OONI: CC BY 4.0 · Cloudflare Radar: CC BY-NC 4.0 · Access Now STOP Dataset: CC BY 4.0).
          Our processing pipeline, update cadences, and classification logic are documented on each
          subpage and open for independent review.
        </p>
      </div>
    </div>

    <!-- Attribution -->
    <div class="mt-12 pt-8 border-t border-white/10 text-xs font-mono opacity-40">
      Data sources: OONI Explorer · Cloudflare Radar · NetBlocks · RIPEstat · IODA · Access Now STOP Dataset ·
      <a href="https://explorer.ooni.org/country/MM" target="_blank" rel="noopener" class="hover:opacity-100">explorer.ooni.org/country/MM</a>
    </div>
  </div>
</Observatory>
