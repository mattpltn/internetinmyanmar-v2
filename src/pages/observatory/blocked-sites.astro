---
import Observatory from '../../layouts/Observatory.astro'
import stats from '../../content/observatory/stats.json'
import blockedData from '../../data/blocked-sites.json'
import OoniCategoryChart from '../../components/charts/OoniCategoryChart.astro'

export const prerender = true

const categoryColors: Record<string, string> = {
  'Social Media':       'var(--color-danger)',
  'News & Media':       'var(--color-warning)',
  'Civil Society':      '#a78bfa',
  'VPN & Circumvention':'var(--color-accent)',
}
---
<Observatory
  title="Blocked Sites Monitor — Myanmar"
  seoTitle="Myanmar Blocked Sites Monitor | Internet in Myanmar"
  metaDescription="Confirmed blocked domains across Myanmar ISPs based on OONI measurements. Updated twice daily."
  lastUpdated={blockedData.lastUpdated}
  datasetName="Myanmar Blocked Websites Database"
  datasetDescription="Confirmed blocked domains across Myanmar ISPs, validated via OONI Explorer network measurements. Categorised by type: social media, news, civil society, VPN tools."
  pageUrl="https://www.internetinmyanmar.com/observatory/blocked-sites/"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="font-headline text-3xl md:text-4xl mb-4">Blocked Sites Monitor</h2>
    <p class="opacity-70 mb-8 max-w-2xl">
      Domains with high censorship anomaly rates across Myanmar ISPs, based on
      <a href="https://explorer.ooni.org/country/MM" target="_blank" rel="noopener" class="text-[color:var(--color-accent)] hover:underline">OONI Explorer</a>
      web_connectivity measurements since January 2024.
      A domain is listed when ≥60% of tests return anomalous results across ≥10 measurements.
    </p>

    <!-- Summary stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      <div class="border border-white/10 rounded-lg p-4 text-center">
        <div class="font-mono text-2xl font-bold text-[color:var(--color-danger)] mb-1">{stats.blockedSites}</div>
        <div class="text-xs opacity-60">Total monitored</div>
      </div>
      {blockedData.categories.map(cat => (
        <div class="border border-white/10 rounded-lg p-4 text-center">
          <div class="font-mono text-2xl font-bold mb-1" style={`color: ${categoryColors[cat.name] ?? 'var(--color-accent)'}`}>{cat.count}</div>
          <div class="text-xs opacity-60">{cat.name}</div>
        </div>
      ))}
    </div>

    <OoniCategoryChart />

    <!-- Category filter tabs -->
    <div id="filter-tabs" class="flex flex-wrap gap-2 mb-6">
      <button data-cat="all" class="filter-btn active px-3 py-1.5 rounded font-mono text-xs border border-white/20 bg-white/10">
        All ({blockedData.totalDomains})
      </button>
      {blockedData.categories.map(cat => (
        <button data-cat={cat.name} class="filter-btn px-3 py-1.5 rounded font-mono text-xs border border-white/10 hover:border-white/30 transition-colors"
          style={`color: ${categoryColors[cat.name] ?? '#fff'}`}>
          {cat.name} ({cat.count})
        </button>
      ))}
    </div>

    <!-- Blocked sites table -->
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="blocked-table">
        <thead>
          <tr class="border-b border-white/10 text-left font-mono text-xs opacity-50">
            <th class="pb-2 pr-4">Domain</th>
            <th class="pb-2 pr-4">Category</th>
            <th class="pb-2 pr-4 text-right">Anomaly Rate</th>
            <th class="pb-2 pr-4 text-right">Tests</th>
            <th class="pb-2">OONI</th>
          </tr>
        </thead>
        <tbody>
          {blockedData.sites.map(site => (
            <tr class="border-b border-white/5 hover:bg-white/2 site-row" data-cat={site.category}>
              <td class="py-2 pr-4 font-mono text-xs">{site.domain}</td>
              <td class="py-2 pr-4">
                <span class="text-xs px-2 py-0.5 rounded-full border" style={`color: ${categoryColors[site.category] ?? '#fff'}; border-color: ${categoryColors[site.category] ?? '#fff'}40`}>
                  {site.category}
                </span>
              </td>
              <td class="py-2 pr-4 text-right font-mono text-xs">
                <!-- Inline bar -->
                <span class="inline-flex items-center gap-2">
                  <span class="block h-1.5 rounded" style={`width:${Math.round(site.rate * 0.6)}px; background:${site.rate > 80 ? 'var(--color-danger)' : site.rate > 60 ? 'var(--color-warning)' : 'var(--color-accent)'}`}></span>
                  <span style={site.rate > 80 ? 'color:var(--color-danger)' : site.rate > 60 ? 'color:var(--color-warning)' : ''}>{site.rate}%</span>
                </span>
              </td>
              <td class="py-2 pr-4 text-right font-mono text-xs opacity-50">{site.total.toLocaleString()}</td>
              <td class="py-2">
                <a href={`https://explorer.ooni.org/chart/mat?probe_cc=MM&test_name=web_connectivity&domain=${site.domain}&since=2024-01-01`}
                  target="_blank" rel="noopener"
                  class="text-[color:var(--color-accent)] font-mono text-xs hover:underline opacity-60 hover:opacity-100">
                  chart →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-8 text-xs font-mono opacity-30">
      Source: <a href="https://api.ooni.io/api/v1/aggregation?probe_cc=MM&test_name=web_connectivity&since=2024-01-01" target="_blank" rel="noopener" class="hover:opacity-100 underline">OONI API aggregation</a>
      · Period: {blockedData.periodStart} – present · Updated by ooni_watcher.py agent
    </div>

    <div class="mt-16 border-t border-white/10 pt-10 max-w-3xl">
      <h2 class="font-headline text-xl mb-6">Measurement Methodology</h2>
      <div class="space-y-5 text-sm leading-relaxed opacity-80">

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-warning)] uppercase tracking-widest mb-2">Domain Inclusion Criteria</h3>
          <p>
            A domain is listed when it meets both thresholds across
            <a href="https://ooni.org" target="_blank" rel="noopener" class="underline hover:opacity-100">OONI</a>'s
            <code class="font-mono text-xs opacity-70">web_connectivity</code> test measurements
            for Myanmar since January 2024: an anomaly rate of ≥60% across ≥10 independent test
            measurements. An anomaly is recorded when an OONI probe detects a discrepancy between
            the test network result and a control measurement taken outside Myanmar — including DNS
            lookup failures, TCP connection resets, or HTTP-level interference consistent with
            transparent proxying or block pages. The <em>confirmed</em> count represents
            measurements where blocking was unambiguously verified against a known block page
            fingerprint registered in OONI's database.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-warning)] uppercase tracking-widest mb-2">Test List Curation</h3>
          <p>
            OONI tests domains from the
            <a href="https://github.com/citizenlab/test-lists" target="_blank" rel="noopener" class="underline hover:opacity-100">Citizen Lab Global Test List</a>
            and the Myanmar country-specific list, supplemented by URLs submitted by local
            researchers and civil society organizations. The list is not exhaustive: domains
            absent from the test list cannot be detected regardless of blocking status. Coverage
            is strongest for high-profile targets — major social media platforms, international
            news outlets, established circumvention tools — and weaker for smaller independent
            publishers, community media, and recently launched platforms.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-warning)] uppercase tracking-widest mb-2">Category Taxonomy</h3>
          <p>
            Domains are classified into four categories reflecting the primary censorship targets
            documented since the 2021 military coup:
            <strong>Social Media</strong> (platforms used for coordination, journalism, and protest
            organisation — Facebook, Twitter/X, Instagram, TikTok);
            <strong>News & Media</strong> (independent outlets and international broadcasters
            including DVB, Irrawaddy, RFA, VOA);
            <strong>Civil Society</strong> (human rights organisations, advocacy groups, legal aid
            providers, election monitoring bodies);
            <strong>VPN & Circumvention</strong> (tools enabling bypass of censorship controls,
            which have been systematically blocked alongside the platforms they protect — a pattern
            consistent with escalating censorship infrastructure rather than targeted takedowns).
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-warning)] uppercase tracking-widest mb-2">Category Block Rate Chart</h3>
          <p>
            The <em>Average Block Rate by Category</em> horizontal bar chart aggregates the anomaly
            rate across all domains within each category and displays the mean as a single figure.
            This reveals the structural pattern of censorship: categories with consistently high
            average block rates indicate systematic targeting rather than incidental interference.
            A category averaging 80%+ is effectively inaccessible without circumvention; 40–79%
            indicates selective or unstable blocking; below 40% suggests partial enforcement or
            ISP-level variation. The chart is computed from the same OONI aggregation data as the
            domain table and is updated twice daily.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-warning)] uppercase tracking-widest mb-2">ISP Coverage & Limitations</h3>
          <p>
            Myanmar operates multiple ISPs with varying compliance levels. A domain flagged as
            blocked reflects aggregate measurements across all available probe vantage points;
            ISP-specific access may differ. MPT (state-owned) and Mytel (military-linked) show
            the highest confirmed block rates. Ooredoo and Atom Myanmar have exhibited more variable
            compliance patterns since 2022. ISP-level breakdowns per domain are available via
            <a href="https://explorer.ooni.org/chart/mat?probe_cc=MM&test_name=web_connectivity" target="_blank" rel="noopener" class="underline hover:opacity-100">OONI Explorer</a>.
            The domain list is refreshed twice daily from the OONI aggregation API.
            For shutdown-scale anomaly trends across all tested URLs, see the
            <a href="/observatory/shutdown-tracker/" class="underline hover:opacity-100">Shutdown Tracker</a>.
          </p>
        </div>

      </div>
    </div>
  </div>

  <script>
    // Category filter
    const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
    const rows = document.querySelectorAll<HTMLTableRowElement>('.site-row')

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active', 'bg-white/10'))
        tab.classList.add('active', 'bg-white/10')
        const cat = tab.dataset.cat
        rows.forEach(row => {
          row.style.display = (cat === 'all' || row.dataset.cat === cat) ? '' : 'none'
        })
      })
    })
  </script>
</Observatory>
