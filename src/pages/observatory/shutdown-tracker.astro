---
import Observatory from '../../layouts/Observatory.astro'
import CfRadarBanner from '../../components/CfRadarBanner.astro'
import stats from '../../content/observatory/stats.json'
import history from '../../data/ooni-history.json'
import historyWeekly from '../../data/ooni-history-weekly.json'
import historyDaily from '../../data/ooni-history-daily.json'
import cfOutages from '../../data/cf-radar-outages.json'
import cfTraffic from '../../data/cf-traffic.json'
import OoniBreakdownChart from '../../components/charts/OoniBreakdownChart.astro'
import keepitonData from '../../data/keepiton-shutdowns.json'

const TYPE_LABELS: Record<string, string> = {
  full_network: 'Full network',
  mobile:       'Mobile',
  platform:     'Platform',
  throttle:     'Throttle',
}
const TYPE_COLORS: Record<string, string> = {
  full_network: 'var(--color-danger)',
  mobile:       'var(--color-warning)',
  platform:     '#a78bfa',
  throttle:     '#64748b',
}

export const prerender = true

// Narrative events with contextual labels — merged with actual anomaly data from history
const narrativeEvents: Record<string, string> = {
  '2021-02': 'Military coup — mass shutdowns begin',
  '2021-03': 'Social media blocked (Facebook, Twitter, Instagram)',
  '2021-07': 'Nightly internet curfews imposed (1–9 AM)',
  '2022-02': 'Coup anniversary — major network outage',
  '2022-09': 'Arakan Army offensive — Rakhine blackouts',
  '2023-01': 'Telenor sold to military-linked KBZMS — General License revoked',
  '2023-10': 'Three Brotherhood Alliance offensive — Shan State blackouts',
  '2024-02': 'Mandatory conscription law — surge in VPN use and connectivity cuts',
  '2024-04': 'Operation 1027 fallout — Mandalay region disruptions',
  '2024-10': 'Escalating Arakan Army offensive — Rakhine & Chin internet cuts',
  '2025-02': 'Coup anniversary — internet restricted in major cities',
  '2025-06': 'Nationwide 5G rollout blocked; military tightens licensing',
  '2025-10': 'BGP withdrawals spike — multiple ISP disruptions across Sagaing and Mandalay',
  '2026-02': 'Coup +5 years — sustained mobile network throttling nationwide',
}

// Build enriched key events: narrative events augmented with measured anomaly rate
const historyMap = Object.fromEntries(history.map(r => [r.month, r]))
const keyEvents = Object.entries(narrativeEvents)
  .map(([date, label]) => ({
    date,
    label,
    rate: historyMap[date]?.anomaly_rate ?? null,
    anomalies: historyMap[date]?.anomaly_count ?? null,
  }))
  .sort((a, b) => a.date.localeCompare(b.date))

const totalMeasurements = history.reduce((s, r) => s + r.measurement_count, 0)

// Limit weekly/daily to the window covered by CF data (agent only keeps 52 weeks / 30 days)
const cfWeeklyCount = cfTraffic.weekly?.length ?? 52
const cfDailyCount  = cfTraffic.daily?.length  ?? 30
const historyWeeklyTrimmed = historyWeekly.slice(-cfWeeklyCount)
const historyDailyTrimmed  = historyDaily.slice(-cfDailyCount)

// CF monthly traffic lookup for the table
const cfMonthlyMap = Object.fromEntries(
  (cfTraffic.monthly || []).map((p: {month: string, cf_traffic: number}) => [p.month, p.cf_traffic])
)

// ── KeepItOn region stats for map view ───────────────────────────────────────
const REGION_DEFS = [
  { id: 'ayeyarwady', label: 'Ayeyarwady Region',         keywords: ['ayeyarwady'] },
  { id: 'bago',       label: 'Bago Region',               keywords: ['bago'] },
  { id: 'chin',       label: 'Chin State',                keywords: ['chin'] },
  { id: 'kachin',     label: 'Kachin State',              keywords: ['kachin'] },
  { id: 'kayah',      label: 'Kayah State',               keywords: ['kayah'] },
  { id: 'kayin',      label: 'Kayin State',               keywords: ['kayin'] },
  { id: 'magway',     label: 'Magway Region',             keywords: ['magway', 'magwe', 'yaw region'] },
  { id: 'mandalay',   label: 'Mandalay Region',           keywords: ['mandalay', 'mogok', 'pyinoolwin', 'mahlaing', 'thabeikkyin', 'nyaung-u'] },
  { id: 'mon',        label: 'Mon State',                 keywords: ['mon state'] },
  { id: 'rakhine',    label: 'Rakhine State',             keywords: ['rakhine', 'arakan', 'ramree', 'kyaukpyu'] },
  { id: 'sagaing',    label: 'Sagaing Region',            keywords: ['sagaing', 'monywa', 'kale', 'kalay', 'tamu', 'indaw', 'banmauk', 'salingyi', 'budalin', 'kani', 'pale', 'homalin', 'namtaw'] },
  { id: 'shan',       label: 'Shan State',                keywords: ['shan', 'taunggyi', 'loikaw', 'hsihseng', 'naungcho', 'ywangan', 'kyaukme', 'namtu', 'man san'] },
  { id: 'tanintharyi',label: 'Tanintharyi Region',        keywords: ['tanintharyi', 'dawei', 'launglon', 'yebyu', 'palaw', 'myeik', 'kawthaung'] },
  { id: 'yangon',     label: 'Yangon Region',             keywords: ['yangon', 'rangoon', 'thanlyin', 'mingaladon', 'bahan', 'sanchaung', 'north okkalapa'] },
  { id: 'naypyidaw',  label: 'Naypyidaw Union Territory', keywords: ['naypyidaw', 'nay pyi taw'] },
]

function matchRegions(scope: string): string[] {
  const s = scope.toLowerCase()
  if (/nationwide|across myanmar|cities and townships across myanmar/i.test(s)) {
    return REGION_DEFS.map(r => r.id)
  }
  return REGION_DEFS.filter(r => r.keywords.some(k => s.includes(k))).map(r => r.id)
}

interface RegionStat {
  label: string
  count: number
  types: Record<string, number>
  minDate: string
  maxDate: string
}
const regionStats: Record<string, RegionStat> = Object.fromEntries(
  REGION_DEFS.map(r => [r.id, { label: r.label, count: 0, types: {}, minDate: '', maxDate: '' }])
)
for (const ev of keepitonData.events) {
  for (const rid of matchRegions(ev.scope)) {
    const rs = regionStats[rid]
    rs.count++
    rs.types[ev.type] = (rs.types[ev.type] ?? 0) + 1
    if (!rs.minDate || ev.startDate < rs.minDate) rs.minDate = ev.startDate
    const endKey = ev.ongoing ? '9999' : (ev.endDate ?? ev.startDate)
    if (!rs.maxDate || endKey > rs.maxDate) rs.maxDate = ev.endDate ?? ev.startDate
  }
}

// Flat event list with pre-matched regions (for timeline slider in the browser)
const kitEventsWithRegions = keepitonData.events.map(ev => ({
  startDate: ev.startDate,
  endDate:   ev.endDate,
  ongoing:   ev.ongoing,
  type:      ev.type,
  regions:   matchRegions(ev.scope),
}))
---
<Observatory
  title="Myanmar Internet Shutdown Tracker"
  seoTitle="Myanmar Shutdown Tracker | Internet in Myanmar"
  metaDescription="Documented timeline of internet shutdowns and service disruptions in Myanmar since the 2021 military coup."
  lastUpdated={stats.lastUpdated}
  datasetName="Myanmar Internet Shutdown Timeline"
  datasetDescription="Documented timeline of internet shutdowns and service disruptions in Myanmar since the 2021 military coup, sourced from OONI, NetBlocks, and Cloudflare Radar."
  pageUrl="https://www.internetinmyanmar.com/observatory/shutdown-tracker/"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="font-headline text-3xl md:text-4xl mb-4">Shutdown Tracker</h2>
    <p class="opacity-70 mb-8 max-w-2xl">
      Documented shutdowns sourced from OONI measurements, NetBlocks, and Cloudflare Radar.
      The Myanmar military junta has used internet shutdowns as a tool of political repression since the February 2021 coup.
    </p>

    <div class="border border-[color:var(--color-warning)]/40 bg-[color:var(--color-warning)]/5 rounded-lg p-6 mb-6">
      <div class="font-mono text-xs text-[color:var(--color-warning)] mb-2 uppercase tracking-widest">Current status</div>
      {stats.activeShutdowns > 0
        ? <div class="text-2xl font-bold mb-1 text-[color:var(--color-danger)]">{stats.activeShutdowns} active shutdown{stats.activeShutdowns !== 1 ? 's' : ''} detected</div>
        : <div class="text-2xl font-bold mb-1 opacity-70">No active shutdowns detected</div>
      }
      <div class="text-sm opacity-60">
        As of {new Date(stats.lastUpdated).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
        · {stats.rawAnomaliesLast24h} anomal{stats.rawAnomaliesLast24h !== 1 ? 'ies' : 'y'} in last 24h across {stats.totalMeasurementsScanned} measurements
      </div>
    </div>

    <CfRadarBanner
      activeOutages={cfOutages.activeOutages}
      lastUpdated={cfOutages.lastUpdated}
    />

    <!-- Chart: scale toggles + Chart.js mixed bar+line -->
    <div class="mb-10">
      <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
        <div>
          <h2 class="font-headline text-xl">OONI Anomaly Rate + CF Traffic Volume</h2>
          <p class="text-xs opacity-40 font-mono mt-0.5">
            Bars = OONI anomaly % · Teal line = CF Radar traffic (100% = peak, last 12 months)
          </p>
        </div>
        <div class="flex gap-1 font-mono text-xs">
          <button class="scale-btn px-3 py-1.5 rounded border transition-colors" data-scale="monthly">5Y · monthly</button>
          <button class="scale-btn px-3 py-1.5 rounded border border-white/10 transition-colors" data-scale="weekly">1Y · weekly</button>
          <button class="scale-btn px-3 py-1.5 rounded border border-white/10 transition-colors" data-scale="daily">1M · daily</button>
        </div>
      </div>
      <div class="border border-white/10 rounded-lg p-4">
        <canvas id="ooni-chart" style="width:100%;height:220px"></canvas>
      </div>
      <div class="text-xs font-mono opacity-30 mt-2 flex flex-wrap gap-x-3">
        <span>OONI: <a href="https://api.ooni.io" target="_blank" rel="noopener" class="hover:opacity-100 underline">api.ooni.io</a> · {history.length} months · {totalMeasurements.toLocaleString()} measurements</span>
        <span>CF Radar: traffic volume normalised · CC BY-NC 4.0</span>
      </div>
    </div>

    <div class="mb-10">
      <h2 class="font-headline text-xl mb-4">Key Events</h2>
      <div class="space-y-0">
        {keyEvents.map((event) => (
          <div class="flex gap-4 items-start border-l-2 border-[color:var(--color-warning)]/30 pl-4 pb-6 relative">
            <div class="absolute -left-[5px] top-0 w-2 h-2 rounded-full bg-[color:var(--color-warning)]"></div>
            <div class="font-mono text-xs text-[color:var(--color-warning)] mt-0.5 whitespace-nowrap min-w-[4rem]">{event.date}</div>
            <div>
              <div class="text-sm">{event.label}</div>
              {event.rate !== null && (
                <div class="font-mono text-xs mt-0.5 opacity-50">
                  {event.rate}% anomaly rate · {(event.anomalies ?? 0).toLocaleString()} anomalies measured
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- KeepItOn verified shutdowns — list + map toggle -->
    {keepitonData.events.length > 0 && (
      <div class="mb-10" id="kit-section">
        <!-- Header + toggle -->
        <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
          <div>
            <h2 class="font-headline text-xl">Verified Shutdowns</h2>
            <p class="text-xs font-mono opacity-40 mt-0.5">
              Access Now STOP Dataset · human-verified events · {keepitonData.totalEvents} Myanmar records
            </p>
          </div>
          <div class="flex items-center gap-3 flex-wrap">
            <!-- View toggle -->
            <div class="flex font-mono text-xs rounded border border-white/15 overflow-hidden">
              <button id="kit-list-btn"
                class="px-3 py-1.5 bg-white/10 text-white transition-colors"
                aria-pressed="true">
                ☰ List
              </button>
              <button id="kit-map-btn"
                class="px-3 py-1.5 text-white/50 hover:text-white transition-colors"
                aria-pressed="false">
                ⬡ Map
              </button>
            </div>
            <a href="/data/keepiton-shutdowns.json" class="text-xs font-mono opacity-40 hover:opacity-70 transition-opacity">↓ JSON</a>
          </div>
        </div>

        <!-- LIST VIEW -->
        <div id="kit-list-view">
          <div class="space-y-0 border border-white/10 rounded-lg overflow-hidden">
            {[...keepitonData.events].reverse().map(ev => (
              <div class="flex flex-wrap gap-3 items-start px-4 py-3 border-b border-white/5 last:border-0 hover:bg-white/[0.02]">
                <span class="inline-block font-mono text-xs px-2 py-0.5 rounded-full border flex-shrink-0 mt-0.5"
                  style={`color:${TYPE_COLORS[ev.type] ?? '#fff'};border-color:${TYPE_COLORS[ev.type] ?? '#fff'}40`}>
                  {TYPE_LABELS[ev.type] ?? ev.type}
                </span>
                <span class="font-mono text-xs opacity-70 flex-shrink-0 mt-0.5">
                  {ev.startDate} → {ev.ongoing ? 'present' : (ev.endDate ?? '?')}
                </span>
                <span class="text-sm opacity-80 flex-1 min-w-0">
                  {ev.scope}{ev.perpetrator ? ` · ${ev.perpetrator}` : ''}
                </span>
                {ev.sourceUrl && (
                  <a href={ev.sourceUrl} target="_blank" rel="noopener noreferrer"
                    class="font-mono text-xs text-[color:var(--color-accent)] opacity-50 hover:opacity-100 flex-shrink-0 mt-0.5">
                    source →
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- MAP VIEW -->
        <div id="kit-map-view" class="hidden">

          <!-- Timeline scrubber -->
          <div class="mb-5 px-1">
            <div class="flex items-center gap-3 mb-2">
              <span class="font-mono text-[10px] opacity-35 w-14 flex-shrink-0">2021-02</span>
              <input type="range" id="kit-timeline"
                min="0" max="100" value="100"
                class="flex-1 cursor-pointer h-1.5 rounded-full appearance-none bg-white/10 accent-[color:var(--color-accent)]"
                aria-label="Scrub through time" />
              <span class="font-mono text-[10px] opacity-35 w-14 flex-shrink-0 text-right" id="kit-end-label">now</span>
            </div>
            <div class="text-center">
              <span class="font-headline text-base" id="kit-date-display">All time</span>
              <span class="font-mono text-xs opacity-50 ml-3" id="kit-active-summary"></span>
            </div>
          </div>

          <!-- Map + right panel -->
          <div class="flex flex-col lg:flex-row gap-6 items-start">

            <!-- Large SVG map (responsive) -->
            <div class="relative mx-auto lg:mx-0 flex-shrink-0" style="width:min(100%,300px)">
              <svg id="kit-svg"
                viewBox="0 0 210 440"
                style="width:100%;height:auto;display:block"
                role="img"
                aria-label="Myanmar regions coloured by verified shutdown event count"
                class="overflow-visible">

                <path id="r-kachin"      d="M 70,2 L 208,2 L 208,90 L 148,95 L 126,75 L 106,82 L 86,70 L 70,48 Z"/>
                <path id="r-sagaing"     d="M 18,55 L 70,48 L 86,70 L 86,105 L 80,132 L 70,155 L 52,168 L 35,180 L 18,170 L 8,145 L 10,100 L 18,68 Z"/>
                <path id="r-chin"        d="M 8,145 L 35,145 L 52,168 L 48,198 L 30,210 L 10,206 L 6,182 Z"/>
                <path id="r-mandalay"    d="M 86,70 L 126,75 L 128,110 L 118,145 L 100,158 L 83,152 L 80,132 L 86,105 Z"/>
                <path id="r-magway"      d="M 35,145 L 80,132 L 83,152 L 78,182 L 66,202 L 50,212 L 38,200 L 50,182 L 52,165 Z"/>
                <path id="r-shan"        d="M 126,75 L 208,90 L 208,222 L 176,224 L 150,222 L 130,200 L 116,178 L 118,145 L 128,110 Z"/>
                <path id="r-kayah"       d="M 130,200 L 150,200 L 148,222 L 130,228 L 118,220 L 118,200 Z"/>
                <path id="r-naypyidaw"   d="M 94,168 L 106,168 L 106,182 L 94,182 Z"/>
                <path id="r-bago"        d="M 83,152 L 116,152 L 118,172 L 116,200 L 106,218 L 88,224 L 78,214 L 70,200 L 78,178 Z"/>
                <path id="r-ayeyarwady"  d="M 38,200 L 66,200 L 70,214 L 78,225 L 76,255 L 66,272 L 50,278 L 34,268 L 26,248 L 30,226 Z"/>
                <path id="r-yangon"      d="M 78,220 L 106,218 L 108,238 L 100,262 L 84,265 L 74,254 L 76,235 Z"/>
                <path id="r-rakhine"     d="M 6,182 L 35,182 L 50,212 L 46,238 L 38,260 L 24,272 L 10,262 L 6,235 L 6,206 Z"/>
                <path id="r-mon"         d="M 108,238 L 130,236 L 128,268 L 118,278 L 106,274 L 100,262 L 108,250 Z"/>
                <path id="r-kayin"       d="M 118,220 L 150,222 L 148,246 L 133,258 L 120,250 L 118,236 L 118,222 Z"/>
                <path id="r-tanintharyi" d="M 118,278 L 133,260 L 148,268 L 148,295 L 142,325 L 134,355 L 126,385 L 118,415 L 110,420 L 110,390 L 114,355 L 113,318 L 112,288 Z"/>

                <text x="140" y="48"  class="kit-label">Kachin</text>
                <text x="36"  y="120" class="kit-label">Sagaing</text>
                <text x="20"  y="178" class="kit-label">Chin</text>
                <text x="102" y="115" class="kit-label">Mandalay</text>
                <text x="55"  y="178" class="kit-label">Magway</text>
                <text x="165" y="158" class="kit-label">Shan</text>
                <text x="136" y="214" class="kit-label" style="font-size:5.5px">Kayah</text>
                <text x="94"  y="177" class="kit-label" style="font-size:5.5px">NPT</text>
                <text x="92"  y="194" class="kit-label">Bago</text>
                <text x="50"  y="245" class="kit-label">Ayeyarwady</text>
                <text x="87"  y="247" class="kit-label">Yangon</text>
                <text x="16"  y="230" class="kit-label">Rakhine</text>
                <text x="112" y="257" class="kit-label" style="font-size:5.5px">Mon</text>
                <text x="132" y="237" class="kit-label" style="font-size:5.5px">Kayin</text>
                <text x="128" y="348" class="kit-label">Tanintharyi</text>
              </svg>

              <!-- Floating tooltip (positioned by JS) -->
              <div id="kit-tooltip"
                class="hidden absolute z-50 pointer-events-none bg-[#0a1628] border border-white/20 rounded-lg p-3 w-52 text-xs shadow-xl"
                style="top:0;left:0">
                <div class="font-headline text-sm mb-1" id="tt-name"></div>
                <div class="font-mono opacity-55 mb-1.5" id="tt-count"></div>
                <div class="font-mono opacity-40 text-[10px] mb-2" id="tt-dates"></div>
                <div id="tt-types" class="space-y-1"></div>
              </div>
            </div>

            <!-- Right panel: compact legend + region list -->
            <div class="flex-1 min-w-0 space-y-5 lg:pt-0">

              <!-- Compact heat scale -->
              <div>
                <div class="text-[10px] font-mono opacity-40 mb-2 uppercase tracking-wider">Events per region</div>
                <div class="flex gap-3 flex-wrap">
                  {[
                    { label: 'None',  fill: '#1a2a3a',              border: 'rgba(255,255,255,0.08)' },
                    { label: '1–2',   fill: 'rgba(245,158,11,0.22)', border: 'rgba(245,158,11,0.4)' },
                    { label: '3–5',   fill: 'rgba(245,158,11,0.48)', border: 'rgba(245,158,11,0.65)' },
                    { label: '6–10',  fill: 'rgba(239,100,50,0.65)', border: 'rgba(239,100,50,0.8)' },
                    { label: '11+',   fill: 'rgba(239,68,68,0.88)',  border: 'rgba(239,68,68,1)'   },
                  ].map(l => (
                    <div class="flex items-center gap-1.5">
                      <div class="w-3.5 h-3.5 rounded-sm flex-shrink-0" style={`background:${l.fill};border:1px solid ${l.border}`}/>
                      <span class="font-mono text-[10px] opacity-55">{l.label}</span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Type legend -->
              <div>
                <div class="text-[10px] font-mono opacity-40 mb-2 uppercase tracking-wider">Type</div>
                <div class="flex flex-wrap gap-x-4 gap-y-1.5">
                  {(Object.entries(TYPE_LABELS) as [string, string][]).map(([k, v]) => (
                    <div class="flex items-center gap-1.5">
                      <div class="w-2 h-2 rounded-full flex-shrink-0" style={`background:${TYPE_COLORS[k]}`}/>
                      <span class="font-mono text-[10px] opacity-55">{v}</span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Region breakdown (sorted by count) -->
              <div>
                <div class="text-[10px] font-mono opacity-40 mb-2 uppercase tracking-wider">By region · all time</div>
                <div class="space-y-0.5">
                  {REGION_DEFS
                    .map(r => ({ ...r, stat: regionStats[r.id] }))
                    .filter(r => r.stat.count > 0)
                    .sort((a, b) => b.stat.count - a.stat.count)
                    .map(r => (
                      <div class="flex items-center gap-2 font-mono text-[11px] py-0.5">
                        <div class="w-1 h-4 rounded-full flex-shrink-0" style={`background:${
                          r.stat.count >= 11 ? 'rgba(239,68,68,0.9)' :
                          r.stat.count >= 6  ? 'rgba(239,100,50,0.8)' :
                          r.stat.count >= 3  ? 'rgba(245,158,11,0.7)' :
                                               'rgba(245,158,11,0.35)'
                        }`}/>
                        <span class="opacity-65 flex-1 truncate">{r.label}</span>
                        <span class="opacity-80 tabular-nums">{r.stat.count}</span>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>

        <p class="text-xs font-mono opacity-25 mt-3">
          Source: <a href="https://www.accessnow.org/keepiton/" target="_blank" rel="noopener" class="underline hover:opacity-60">Access Now STOP Dataset</a>
          · verified by Access Now researchers · updated weekly ·
          <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener" class="underline hover:opacity-60">CC BY 4.0</a>
        </p>
      </div>
    )}

    <OoniBreakdownChart />

    <div>
      <h2 class="font-headline text-xl mb-4">Recent Monthly Measurements</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm font-mono">
          <thead>
            <tr class="text-left">
              <th class="pb-1 pr-6"></th>
              <th colspan="4" class="pb-1 pr-2 text-xs text-[color:var(--color-warning)] opacity-70 font-mono tracking-wider">OONI</th>
              <th class="pb-1 text-xs text-[color:var(--color-accent)] opacity-70 font-mono tracking-wider text-right">Cloudflare Radar</th>
            </tr>
            <tr class="border-b border-white/10 text-left opacity-50">
              <th class="pb-2 pr-6">Month</th>
              <th class="pb-2 pr-6 text-right">Measurements</th>
              <th class="pb-2 pr-6 text-right">Anomalies</th>
              <th class="pb-2 pr-6 text-right">Confirmed</th>
              <th class="pb-2 pr-6 text-right">Anomaly Rate</th>
              <th class="pb-2 text-right">Traffic Level</th>
            </tr>
          </thead>
          <tbody>
            {[...history].reverse().slice(0, 12).map((row) => (
              <tr class="border-b border-white/5 hover:bg-white/2">
                <td class="py-2 pr-6">{row.month}</td>
                <td class="py-2 pr-6 text-right opacity-60">{row.measurement_count.toLocaleString()}</td>
                <td class="py-2 pr-6 text-right" style={row.anomaly_rate > 20 ? 'color:var(--color-danger)' : row.anomaly_rate > 10 ? 'color:var(--color-warning)' : ''}>
                  {row.anomaly_count.toLocaleString()}
                </td>
                <td class="py-2 pr-6 text-right opacity-60">{row.confirmed_count.toLocaleString()}</td>
                <td class="py-2 pr-6 text-right" style={row.anomaly_rate > 20 ? 'color:var(--color-danger)' : row.anomaly_rate > 10 ? 'color:var(--color-warning)' : ''}>
                  {row.anomaly_rate}%
                </td>
                <td class="py-2 text-right" style="color:var(--color-accent)">
                  {cfMonthlyMap[row.month] != null
                    ? `${cfMonthlyMap[row.month]}%`
                    : <span class="opacity-20">—</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-16 border-t border-white/10 pt-10 max-w-3xl">
      <h2 class="font-headline text-xl mb-6">Measurement Methodology</h2>

      <div class="space-y-5 text-sm leading-relaxed opacity-80">
        <p>
          This tracker combines four independent data layers — OONI Web Connectivity measurements,
          Cloudflare Radar traffic telemetry, BGP routing surveillance, and Access Now's human-verified
          shutdown registry — cross-corroborated continuously to document network interference and
          internet shutdowns in Myanmar since the February 2021 coup. No single source is treated as
          definitive; shutdown events are classified only when multiple signals converge.
        </p>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-warning)] uppercase tracking-widest mb-2">OONI Web Connectivity</h3>
          <p>
            The primary signal comes from the <a href="https://ooni.org" target="_blank" rel="noopener" class="underline hover:opacity-100">Open Observatory of Network Interference (OONI)</a>,
            a global passive measurement platform that probes web connectivity from volunteer-operated
            vantage points inside Myanmar. Each test fetches a curated URL from within the country
            and compares it against a control measurement taken outside. Discrepancies — DNS lookup
            failures, TCP/IP connection resets, HTTP-level blocking consistent with transparent
            proxying — are classified as anomalies. When anomalies cluster across multiple independent
            probes targeting the same URL or autonomous system, OONI records a confirmed blocking event.
          </p>
          <p class="mt-3">
            We collect this data at three granularities: monthly (since February 2021), weekly (last
            52 weeks), and daily (last 28 days). The main anomaly rate chart shows four stacked
            measurement categories for each period — <em>ok</em> (accessible), <em>failure</em>
            (network error not attributable to blocking), <em>anomaly</em> (probable interference),
            and <em>confirmed</em> (verified blocking against a known block-page fingerprint). The
            <em>OONI Anomaly Breakdown</em> chart below shows this composition as weekly percentage
            shares, revealing whether elevated anomaly rates reflect new confirmed blocks or a
            broader degradation across the probe network.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-accent)] uppercase tracking-widest mb-2">Cloudflare Radar Traffic Overlay</h3>
          <p>
            OONI captures application-layer interference but not total traffic volume. The primary
            chart overlays both signals simultaneously: bars show the OONI anomaly rate (left axis),
            and a teal line shows <a href="https://radar.cloudflare.com" target="_blank" rel="noopener" class="underline hover:opacity-100">Cloudflare Radar</a>
            Myanmar IP traffic on the right axis, normalised to a 0–100 index where 100 is the
            historical peak for the period. The diagnostic value lies in their relationship: a spike
            in anomalies with a simultaneous traffic drop is the strongest indicator of a
            population-level shutdown. Elevated anomalies without a traffic drop points to targeted
            content blocking while general connectivity holds. This distinction matters for
            documentation — a correlated anomaly spike and traffic drop constitutes strong technical
            evidence suitable for citation in legal filings and UN reporting.
          </p>
          <p class="mt-3">
            The three time scales — 5-year monthly, 1-year weekly, 1-month daily — reveal different
            phenomena. Monthly shows the structural arc since the coup. Weekly reveals operational
            tempo: curfews, offensive-linked blackouts. Daily resolves intraday patterns. This
            approach mirrors methodologies used by
            <a href="https://netblocks.org" target="_blank" rel="noopener" class="underline hover:opacity-100">NetBlocks</a> and
            <a href="https://ioda.inetintel.cc.gatech.edu" target="_blank" rel="noopener" class="underline hover:opacity-100">IODA (Georgia Tech / CAIDA)</a>.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-danger)] uppercase tracking-widest mb-2">Access Now STOP Dataset — Verified Shutdowns</h3>
          <p>
            The <em>Verified Shutdowns</em> section draws on the
            <a href="https://www.accessnow.org/keepiton/" target="_blank" rel="noopener" class="underline hover:opacity-100">Access Now STOP Dataset</a>,
            the global gold standard for human-confirmed internet shutdown documentation.
            Each record in this dataset represents a shutdown event that Access Now researchers have
            verified through direct contact with affected communities, cross-referenced with technical
            measurements and contemporaneous media reporting. Fields include start and end date,
            geographic scope, affected services, shutdown type, and the ordering authority where
            attributable.
          </p>
          <p class="mt-3">
            We download the dataset weekly from Access Now's public registry and filter to Myanmar.
            Events are classified into four types: <em>full network</em> (total blackout across fixed
            and mobile); <em>mobile</em> (mobile data cut while fixed broadband continues);
            <em>platform</em> (specific applications blocked — Facebook, WhatsApp, Telegram);
            <em>throttle</em> (connectivity degraded rather than severed). These events are overlaid
            on the main OONI/CF Radar chart as coloured bands — red for full network, amber for
            mobile, purple for platform, slate for throttle — using a worst-type-per-period
            rendering that prevents compounding opacity across simultaneous events. The
            <em>⬡ Map</em> view plots all events by administrative region; the timeline scrubber
            lets you move through any month since 2021 to see which regions were simultaneously
            affected. Hover a region for event count, date range, and type breakdown.
          </p>
          <p class="mt-3">
            OONI anomaly data and Access Now verified events are complementary: OONI provides
            continuous automated coverage across all dates but is limited to URL-level interference
            detectable from probe locations; Access Now records are manually verified and
            geographically attributed but depend on researcher capacity and community reporting.
            When both sources signal the same event, the evidence basis for documentation is
            substantially strengthened.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs opacity-55 uppercase tracking-widest mb-2">BGP Routing Surveillance</h3>
          <p>
            At the routing layer, we monitor Border Gateway Protocol (BGP) update activity for
            Myanmar's registered autonomous systems. Withdrawal of BGP prefixes — the routing
            announcements that make IP address blocks globally reachable — is a definitive technical
            signal of deliberate network disconnection. Our pipeline scans critical Myanmar ASNs
            including MPT (AS9988), Mytel (AS136168), Ooredoo Myanmar (AS132748), and Atom Myanmar
            (AS132167) every five minutes, classifying routing events by severity and probable cause.
            Full BGP history and outage records are available on the
            <a href="/observatory/bgp/" class="underline hover:opacity-100">BGP Network Status</a> page.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs opacity-55 uppercase tracking-widest mb-2">Anomaly Thresholds & Classification</h3>
          <p>
            Anomaly rates above 20% in a measurement period are flagged as high-severity disruptions.
            Rates between 10–20% are marked elevated, warranting contextual analysis. Below 10%,
            measurements are treated as baseline noise absent corroborating signals. Shutdown
            classification is not automated: key events in the timeline have been manually verified
            against reporting from Fortify Rights, Free Expression Myanmar (Athan), the Irrawaddy,
            Democratic Voice of Burma, and international wire services.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs opacity-55 uppercase tracking-widest mb-2">Limitations & Transparency</h3>
          <p>
            OONI coverage depends on active probe density inside Myanmar, which has declined since
            2021 as digital security risks have increased for local researchers. Probe density is
            lowest in active conflict zones — Shan, Kachin, Rakhine — meaning localised shutdowns
            there are underrepresented. Cloudflare Radar reflects traffic transiting Cloudflare's
            network, not total internet; it is a robust proxy, not an absolute measure. Access Now's
            dataset coverage is contingent on researcher and community reporting capacity.
            OONI data: <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener" class="underline hover:opacity-100">CC BY 4.0</a>.
            Cloudflare Radar: CC BY-NC 4.0. Access Now STOP Dataset:
            <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener" class="underline hover:opacity-100">CC BY 4.0</a>.
            All data pipelines and processing scripts are documented and open for independent review.
          </p>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{
    ooniMonthly:    history,
    ooniWeekly:     historyWeeklyTrimmed,
    ooniDaily:      historyDailyTrimmed,
    cfMonthly:      cfTraffic.monthly,
    cfWeekly:       cfTraffic.weekly,
    cfDaily:        cfTraffic.daily,
    keepitonEvents:       keepitonData.events,
    kitRegionStats:       regionStats,
    kitEventsWithRegions: kitEventsWithRegions,
  }}>
    let chart       = null
    let activeScale = 'monthly'

    function buildDatasets(scale) {
      const ooni = { monthly: ooniMonthly, weekly: ooniWeekly, daily: ooniDaily }[scale] || []
      const cf  = { monthly: cfMonthly,   weekly: cfWeekly,   daily: cfDaily   }[scale] || []

      if (!ooni.length) return { labels: [], datasets: [] }

      const labels = ooni.map(d => {
        const p = d.period || d.month || d.measurement_start_day || ''
        if (scale === 'monthly') return p.slice(0, 7)
        try { return new Date(p).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) }
        catch { return p.slice(5, 10) }
      })

      const barColors = ooni.map(d =>
        d.anomaly_rate > 30 ? '#EF4444cc'
        : d.anomaly_rate > 15 ? '#F59E0Bcc'
        : '#7170ff99'
      )

      const datasets = [{
        type: 'bar',
        label: 'OONI Anomaly Rate (%)',
        data: ooni.map(d => d.anomaly_rate),
        backgroundColor: barColors,
        borderRadius: 2,
        yAxisID: 'yOoni',
      }]

      if (cf && cf.length > 0) {
        const cfMap = {}
        cf.forEach(p => {
          let raw = (p.timestamp || p.week || p.date || p.month || '')
          let key
          if (scale === 'monthly') {
            key = raw.slice(0, 7)
          } else if (scale === 'weekly' && p.timestamp) {
            // CF Radar weeks start Monday; OONI weeks start Sunday — shift back 1 day
            const d = new Date(p.timestamp)
            d.setUTCDate(d.getUTCDate() - 1)
            key = d.toISOString().slice(0, 10)
          } else {
            key = raw.slice(0, 10)
          }
          cfMap[key] = p.cf_traffic
        })
        let cfData = ooni.map(d => {
          const key = (d.period || d.month || d.measurement_start_day || '').slice(0, scale === 'monthly' ? 7 : 10)
          return cfMap[key] != null ? cfMap[key] : null
        })
        // Re-normalize to the visible window's peak so the line fills the range meaningfully
        if (scale !== 'monthly') {
          const cfMax = Math.max(...cfData.filter(v => v != null))
          if (cfMax > 0) {
            cfData = cfData.map(v => v != null ? Math.round((v / cfMax) * 1000) / 10 : null)
          }
        }
        datasets.push({
          type: 'line',
          label: 'CF Traffic (% of peak)',
          data: cfData,
          borderColor: '#00D4C8',
          backgroundColor: 'transparent',
          borderWidth: 1.5,
          pointRadius: 0,
          spanGaps: true,
          tension: 0.3,
          yAxisID: 'yCf',
        })
      }

      return { labels, datasets }
    }

    function renderChart() {
      const canvas = document.getElementById('ooni-chart')
      if (!canvas) return
      const ctx = canvas.getContext('2d')
      if (!ctx) return
      if (chart) chart.destroy()
      const { labels, datasets } = buildDatasets(activeScale)

      if (!labels.length) {
        canvas.parentElement.innerHTML = '<p style="opacity:.4;font-size:.75rem;padding:1rem;font-family:monospace">No data for this range yet — agent runs at 8 AM and 8 PM UTC.</p>'
        return
      }

      const keepitonPlugin = {
        id: 'keepitonOverlay',
        afterDraw(ch) {
          if (!keepitonEvents || !keepitonEvents.length) return
          const meta = ch.getDatasetMeta(0)
          if (!meta || !meta.data.length) return
          const { ctx: c, scales: { yOoni } } = ch
          const ooni = { monthly: ooniMonthly, weekly: ooniWeekly, daily: ooniDaily }[activeScale] || []
          const periods = ooni.map(d => d.period || d.month || d.measurement_start_day || '')
          const today = new Date().toISOString().slice(0, 10)

          // Priority: full_network > mobile > platform > throttle
          // Compute one "worst" type per period to avoid compounding opacity from overlapping events
          const priority = { full_network: 4, mobile: 3, platform: 2, throttle: 1 }
          const typeColors = {
            full_network: { fill: 'rgba(239,68,68,0.10)',   stripe: 'rgba(239,68,68,0.75)'  },
            mobile:       { fill: 'rgba(245,158,11,0.09)',  stripe: 'rgba(245,158,11,0.70)' },
            platform:     { fill: 'rgba(139,92,246,0.09)',  stripe: 'rgba(139,92,246,0.70)' },
            throttle:     { fill: 'rgba(100,116,139,0.09)', stripe: 'rgba(100,116,139,0.60)' },
          }

          const worstPerPeriod = periods.map(p => {
            const pk = activeScale === 'monthly' ? p.slice(0, 7) : p.slice(0, 10)
            let worst = null
            keepitonEvents.forEach(ev => {
              const s = activeScale === 'monthly' ? (ev.startDate || '').slice(0, 7) : (ev.startDate || '').slice(0, 10)
              const e = activeScale === 'monthly'
                ? (ev.ongoing ? today.slice(0, 7) : (ev.endDate || today).slice(0, 7))
                : (ev.ongoing ? today : (ev.endDate || today).slice(0, 10))
              if (!s || pk < s || pk > e) return
              if (!worst || priority[ev.type] > priority[worst]) worst = ev.type
            })
            return worst
          })

          c.save()
          const top = yOoni.top, bottom = yOoni.bottom
          const stripeH = 4

          worstPerPeriod.forEach((t, i) => {
            if (!t) return
            const bar = meta.data[i]
            const bw  = bar.width || 8
            const x1  = bar.x - bw / 2
            const colors = typeColors[t]
            // Subtle fill over bar area
            c.fillStyle = colors.fill
            c.fillRect(x1, top + stripeH, bw, bottom - top - stripeH)
            // Solid stripe at top edge
            c.fillStyle = colors.stripe
            c.fillRect(x1, top, bw, stripeH)
          })
          c.restore()
        }
      }

      chart = new window.Chart(ctx, {
        plugins: [keepitonPlugin],
        data: { labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              display: true,
              labels: { color: '#94a3b8', font: { size: 10, family: 'monospace' }, boxWidth: 12, padding: 16 }
            },
            tooltip: {
              backgroundColor: '#0f1f3a',
              titleColor: '#94a3b8',
              bodyColor: '#e2e8f0',
              callbacks: {
                label: c => c.dataset.label.startsWith('OONI')
                  ? ` OONI: ${c.parsed.y}% anomaly rate`
                  : ` CF Traffic: ${c.parsed.y}% of peak`
              }
            }
          },
          scales: {
            x: {
              ticks: { color: '#64748b', font: { size: 9 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 24 },
              grid:  { color: 'rgba(255,255,255,0.04)' }
            },
            yOoni: {
              position: 'left',
              beginAtZero: true,
              max: 100,
              ticks: { color: '#64748b', font: { size: 9 }, callback: v => `${v}%` },
              grid:  { color: 'rgba(255,255,255,0.04)' },
              title: { display: true, text: 'Anomaly %', color: '#64748b', font: { size: 9 } }
            },
            yCf: {
              position: 'right',
              beginAtZero: true,
              max: 100,
              ticks: { color: '#00D4C8', font: { size: 9 }, callback: v => `${v}%` },
              grid:  { display: false },
              title: { display: true, text: 'CF Traffic %', color: '#00D4C8', font: { size: 9 } }
            },
          }
        }
      })
    }

    function setActiveScale(scale) {
      activeScale = scale
      document.querySelectorAll('.scale-btn').forEach(btn => {
        const isActive = btn.dataset.scale === scale
        btn.style.borderColor = isActive ? 'var(--color-accent)' : 'rgba(255,255,255,0.1)'
        btn.style.color       = isActive ? 'var(--color-accent)' : ''
      })
      renderChart()
    }

    // Trigger initial active style on monthly button
    function initButtons() {
      setActiveScale('monthly')
    }

    const s = document.createElement('script')
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js'
    s.onload = () => {
      initButtons()
      document.querySelectorAll('.scale-btn').forEach(btn =>
        btn.addEventListener('click', () => setActiveScale(btn.dataset.scale))
      )
    }
    document.head.appendChild(s)

    // ── KeepItOn map / list toggle + timeline ──────────────────────────────
    ;(function () {
      const listBtn  = document.getElementById('kit-list-btn')
      const mapBtn   = document.getElementById('kit-map-btn')
      const listView = document.getElementById('kit-list-view')
      const mapView  = document.getElementById('kit-map-view')
      if (!listBtn || !mapBtn || !listView || !mapView) return

      // Build month list 2021-01 → current month
      function genMonths() {
        const months = []
        const now = new Date()
        let y = 2021, m = 1
        const ey = now.getFullYear(), em = now.getMonth() + 1
        while (y < ey || (y === ey && m <= em)) {
          months.push(`${y}-${String(m).padStart(2, '0')}`)
          if (++m > 12) { m = 1; y++ }
        }
        return months
      }
      const KIT_MONTHS    = genMonths()
      const slider        = document.getElementById('kit-timeline')
      const dateDisplay   = document.getElementById('kit-date-display')
      const activeSummary = document.getElementById('kit-active-summary')

      if (slider) {
        slider.max   = KIT_MONTHS.length - 1
        slider.value = KIT_MONTHS.length - 1
      }

      // Colour scale
      function rFill(n) {
        return !n ? '#1a2a3a' : n <= 2 ? 'rgba(245,158,11,0.22)' : n <= 5 ? 'rgba(245,158,11,0.48)' : n <= 10 ? 'rgba(239,100,50,0.65)' : 'rgba(239,68,68,0.88)'
      }
      function rStroke(n) {
        return !n ? 'rgba(255,255,255,0.08)' : n <= 2 ? 'rgba(245,158,11,0.40)' : n <= 5 ? 'rgba(245,158,11,0.65)' : n <= 10 ? 'rgba(239,100,50,0.80)' : 'rgba(239,68,68,1)'
      }

      let currentCounts = {}

      function buildCountsAllTime() {
        const c = {}
        Object.entries(kitRegionStats).forEach(([rid, s]) => c[rid] = s.count)
        return c
      }
      function buildCountsAt(month) {
        const c = {}
        Object.keys(kitRegionStats).forEach(rid => c[rid] = 0)
        kitEventsWithRegions.forEach(ev => {
          const s = ev.startDate.slice(0, 7)
          const e = ev.ongoing ? '9999-99' : (ev.endDate ? ev.endDate.slice(0, 7) : s)
          if (s <= month && month <= e)
            ev.regions.forEach(rid => { c[rid] = (c[rid] || 0) + 1 })
        })
        return c
      }

      function paintMap(counts) {
        currentCounts = counts
        Object.entries(counts).forEach(([rid, n]) => {
          const el = document.getElementById('r-' + rid)
          if (!el) return
          el.style.fill        = rFill(n)
          el.style.stroke      = rStroke(n)
          el.style.strokeWidth = '0.8'
        })
      }

      function fmtMonth(m) {
        const [y, mo] = m.split('-')
        return ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][+mo - 1] + ' ' + y
      }

      function updateSlider() {
        if (!slider) return
        const idx       = parseInt(slider.value)
        const isAllTime = idx === KIT_MONTHS.length - 1
        const month     = KIT_MONTHS[idx]
        const counts    = isAllTime ? buildCountsAllTime() : buildCountsAt(month)
        const nRegions  = Object.values(counts).filter(Boolean).length
        const nEvents   = Object.values(counts).reduce((s, n) => s + n, 0)

        paintMap(counts)

        if (dateDisplay) dateDisplay.textContent = isAllTime ? 'All time' : fmtMonth(month)
        if (activeSummary) {
          if (isAllTime) {
            const total = Object.values(kitRegionStats).reduce((s, r) => s + r.count, 0)
            activeSummary.textContent = `${total} events · ${nRegions} regions affected`
          } else if (nEvents === 0) {
            activeSummary.textContent = 'No recorded events this month'
          } else {
            activeSummary.textContent = `${nEvents} active event${nEvents !== 1 ? 's' : ''} · ${nRegions} region${nRegions !== 1 ? 's' : ''}`
          }
        }
      }

      // Tooltip
      const tooltip = document.getElementById('kit-tooltip')
      const ttName  = document.getElementById('tt-name')
      const ttCount = document.getElementById('tt-count')
      const ttDates = document.getElementById('tt-dates')
      const ttTypes = document.getElementById('tt-types')
      const TL = { full_network: 'Full network', mobile: 'Mobile', platform: 'Platform', throttle: 'Throttle' }
      const TC = { full_network: '#ef4444', mobile: '#f59e0b', platform: '#a78bfa', throttle: '#64748b' }

      function showTooltip(rid, cx, cy) {
        const n = currentCounts[rid] || 0
        if (!n) { hideTooltip(); return }
        const stat = kitRegionStats[rid]
        ttName.textContent  = stat.label
        ttCount.textContent = n + ' event' + (n !== 1 ? 's' : '')

        const isAllTime = !slider || parseInt(slider.value) === KIT_MONTHS.length - 1
        let typeCounts = {}
        if (isAllTime) {
          typeCounts = stat.types || {}
          const from = stat.minDate || '—'
          const to   = stat.maxDate && stat.maxDate !== stat.minDate ? ' → ' + stat.maxDate : ''
          ttDates.textContent = from + to
        } else {
          const month = KIT_MONTHS[parseInt(slider.value)]
          ttDates.textContent = 'Active in ' + fmtMonth(month)
          kitEventsWithRegions
            .filter(ev => {
              const s = ev.startDate.slice(0, 7)
              const e = ev.ongoing ? '9999-99' : (ev.endDate ? ev.endDate.slice(0, 7) : s)
              return s <= month && month <= e && ev.regions.includes(rid)
            })
            .forEach(ev => { typeCounts[ev.type] = (typeCounts[ev.type] || 0) + 1 })
        }

        ttTypes.innerHTML = Object.entries(typeCounts).sort((a, b) => b[1] - a[1])
          .map(([t, c]) =>
            `<div style="display:flex;align-items:center;gap:5px">
              <span style="width:7px;height:7px;border-radius:50%;background:${TC[t]||'#fff'};flex-shrink:0;display:inline-block"></span>
              <span style="font-family:monospace;font-size:10px;opacity:.65">${TL[t]||t} · ${c}</span>
            </div>`
          ).join('')

        tooltip.classList.remove('hidden')
        // Keep tooltip inside SVG container
        const wrap  = document.getElementById('kit-svg').parentElement
        const wRect = wrap.getBoundingClientRect()
        const ttW   = 208, ttH = tooltip.offsetHeight || 120
        let tx = cx + 12, ty = cy - 20
        if (tx + ttW > wRect.width) tx = cx - ttW - 8
        if (ty + ttH > wRect.height) ty = wRect.height - ttH - 4
        if (ty < 0) ty = 4
        tooltip.style.left = tx + 'px'
        tooltip.style.top  = ty + 'px'
      }
      function hideTooltip() { tooltip && tooltip.classList.add('hidden') }

      function bindRegionHover() {
        Object.keys(kitRegionStats).forEach(rid => {
          const el = document.getElementById('r-' + rid)
          if (!el) return
          el.style.cursor = 'pointer'
          el.addEventListener('mousemove', e => {
            const rect = el.closest('svg').parentElement.getBoundingClientRect()
            el.style.opacity = '0.8'
            showTooltip(rid, e.clientX - rect.left, e.clientY - rect.top)
          })
          el.addEventListener('mouseleave', () => { el.style.opacity = '1'; hideTooltip() })
        })
      }

      // Toggle
      let mapReady = false
      function showList() {
        listView.classList.remove('hidden')
        mapView.classList.add('hidden')
        listBtn.classList.add('bg-white/10'); listBtn.classList.remove('text-white/50')
        mapBtn.classList.remove('bg-white/10'); mapBtn.classList.add('text-white/50')
        listBtn.setAttribute('aria-pressed', 'true')
        mapBtn.setAttribute('aria-pressed', 'false')
      }
      function showMap() {
        mapView.classList.remove('hidden')
        listView.classList.add('hidden')
        mapBtn.classList.add('bg-white/10'); mapBtn.classList.remove('text-white/50')
        listBtn.classList.remove('bg-white/10'); listBtn.classList.add('text-white/50')
        mapBtn.setAttribute('aria-pressed', 'true')
        listBtn.setAttribute('aria-pressed', 'false')
        if (!mapReady) {
          updateSlider()
          bindRegionHover()
          slider && slider.addEventListener('input', updateSlider)
          mapReady = true
        }
      }

      listBtn.addEventListener('click', showList)
      mapBtn.addEventListener('click',  showMap)
    })()
  </script>

  <style>
    .kit-label {
      font-size: 6.5px;
      fill: rgba(255,255,255,0.55);
      font-family: 'IBM Plex Mono', monospace;
      text-anchor: middle;
      pointer-events: none;
    }
    #kit-svg path {
      transition: fill 0.2s, opacity 0.15s;
    }
  </style>
</Observatory>
