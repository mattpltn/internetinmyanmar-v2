---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import ArticleList from '../../components/ArticleList.astro'

export const prerender = true

const articles = (await getCollection('articles', ({ data }) =>
  !data.draft && !data.unlisted && !data.archived && data.categories.includes('Mobile & Data Plans') && data.lang === 'en'
)).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Mobile & Data Plans — Myanmar"
  seoTitle="Myanmar Mobile Networks & Data Plans | Internet in Myanmar"
  metaDescription="Coverage of Myanmar's mobile operators — MPT, Ooredoo, Mytel, Atom — data pack comparisons, APN settings, and SIM card guides."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-warning)] mb-3 uppercase tracking-widest">Mobile & Data Plans</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Mobile & Data Plans</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Everything about Myanmar's mobile operators — MPT, Ooredoo, Mytel, and Atom — including data pack comparisons, APN settings, SIM registration, and roaming guides.
    </p>
    <ArticleList {articles} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
