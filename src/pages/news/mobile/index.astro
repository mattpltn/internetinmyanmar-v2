---
import { getCollection } from 'astro:content'
import Base from '../../../layouts/Base.astro'
import ArticleList from '../../../components/ArticleList.astro'

export const prerender = true

const articles = (await getCollection('articles', ({ data }) =>
  !data.draft && !data.archived && data.category === 'News - Mobile' && data.lang === 'en'
)).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Mobile Networks News — Myanmar"
  seoTitle="Myanmar Mobile Network News | Internet in Myanmar"
  metaDescription="Latest news on Myanmar's mobile networks — MPT, Mytel, Ooredoo, and the state of mobile connectivity under military rule."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">News</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Mobile Networks</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      News and updates on Myanmar's mobile operators — MPT, Mytel, Ooredoo/ATOM — spectrum, coverage, and the political pressures shaping mobile connectivity.
    </p>
    <ArticleList {articles} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
