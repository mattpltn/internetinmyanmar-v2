---
import { getCollection } from 'astro:content'
import Base from '../../../layouts/Base.astro'
import ArticleList from '../../../components/ArticleList.astro'

export const prerender = true

const articles = (await getCollection('articles', ({ data }) =>
  !data.draft && !data.archived && data.category === 'News - Policy' && data.lang === 'en'
)).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Policy & Regulation News — Myanmar"
  seoTitle="Myanmar Internet Policy & Regulation | Internet in Myanmar"
  metaDescription="Tracking Myanmar's internet regulations, cybersecurity laws, and telecommunications policy under military governance."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">News</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Policy & Regulation</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Myanmar's regulatory landscape — cybersecurity laws, telecom licensing, content regulations, and how military decrees reshape the internet environment.
    </p>
    <ArticleList {articles} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
