---
import { getCollection } from 'astro:content'
import Base from '../../../layouts/Base.astro'
import ArticleList from '../../../components/ArticleList.astro'

export const prerender = true

const articles = (await getCollection('articles', ({ data }) =>
  !data.draft && !data.archived && data.category === 'Guides & Tools' && data.lang === 'en'
)).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Digital Security Guides — Myanmar"
  seoTitle="Myanmar Digital Security Guides | Internet in Myanmar"
  metaDescription="Digital security guides for journalists, activists, and citizens in Myanmar — protecting communications under surveillance."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">Guides & Tools</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Digital Security</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Protecting your digital communications in Myanmar — secure messaging, device security, and operational security for journalists and activists operating under surveillance.
    </p>
    <ArticleList {articles} emptyMessage="No guides published yet." />
  </div>
</Base>
