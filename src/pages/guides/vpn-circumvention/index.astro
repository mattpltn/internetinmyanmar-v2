---
import { getCollection } from 'astro:content'
import Base from '../../../layouts/Base.astro'
import ArticleList from '../../../components/ArticleList.astro'

export const prerender = true

const articles = (await getCollection('articles', ({ data }) =>
  !data.draft && !data.archived && data.category === 'Guides & Tools' && data.lang === 'en'
)).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="VPN & Circumvention Guides — Myanmar"
  seoTitle="Myanmar VPN & Circumvention Guides | Internet in Myanmar"
  metaDescription="Practical guides for using VPNs, Tor, and circumvention tools to access the free internet in Myanmar."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">Guides & Tools</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">VPN & Circumvention</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Practical guides for accessing blocked content in Myanmar — VPNs, Tor, Psiphon, and other circumvention tools tested against Myanmar's censorship infrastructure.
    </p>
    <ArticleList {articles} emptyMessage="No guides published yet." />
  </div>
</Base>
