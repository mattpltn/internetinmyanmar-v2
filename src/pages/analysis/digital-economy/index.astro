---
import { getCollection } from 'astro:content'
import Base from '../../../layouts/Base.astro'
import ArticleList from '../../../components/ArticleList.astro'

export const prerender = true

const articles = (await getCollection('articles', ({ data }) =>
  !data.draft && !data.archived && data.category === 'Digital Economy' && data.lang === 'en'
)).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Digital Economy — Myanmar"
  seoTitle="Myanmar Digital Economy | Internet in Myanmar"
  metaDescription="Tracking Myanmar's digital economy development, fintech, e-commerce, and the economic impact of internet restrictions."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">Reports & Analysis</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Digital Economy</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Analysis of Myanmar's digital economy — fintech adoption, e-commerce, mobile payments, and how internet shutdowns are devastating economic activity.
    </p>
    <ArticleList {articles} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
