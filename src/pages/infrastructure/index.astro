---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import ArticleList from '../../components/ArticleList.astro'
import { digestToArticle } from '../../utils/digestToArticle'

export const prerender = true

const [articleEntries, digestEntries] = await Promise.all([
  getCollection('articles', ({ data }) =>
    !data.draft && !data.archived && data.categories.includes('Telecom & Infrastructure') && data.lang === 'en'
  ),
  getCollection('digest', ({ data }) =>
    !data.draft && data.category === 'Data'
  ),
])

const combined = [
  ...articleEntries,
  ...digestEntries.map(digestToArticle),
].sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Telecom & Infrastructure — Myanmar"
  seoTitle="Myanmar Telecom Infrastructure & Network Architecture | Internet in Myanmar"
  metaDescription="Analysis of Myanmar's telecom infrastructure: 4G spectrum, IXP, IPv6, data centers, and network architecture affecting connectivity."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">Telecom & Infrastructure</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Telecom & Infrastructure</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Technical analysis of Myanmar's telecom infrastructure: spectrum allocation, internet exchange points, IPv6 deployment, data centers, and the network architecture underpinning connectivity.
    </p>
    <ArticleList articles={combined} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
