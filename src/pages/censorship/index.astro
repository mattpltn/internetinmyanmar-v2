---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import ArticleList from '../../components/ArticleList.astro'
import { digestToArticle } from '../../utils/digestToArticle'

export const prerender = true

const DIGEST_CATEGORIES = ['Censorship', 'Shutdown', 'Arrest']

const [articleEntries, digestEntries] = await Promise.all([
  getCollection('articles', ({ data }) =>
    !data.draft && !data.unlisted && !data.archived && data.categories.includes('Censorship & Shutdowns') && data.lang === 'en'
  ),
  getCollection('digest', ({ data }) =>
    !data.draft && DIGEST_CATEGORIES.includes(data.category)
  ),
])

const combined = [
  ...articleEntries,
  ...digestEntries.map(digestToArticle),
].sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Censorship & Shutdowns — Myanmar"
  seoTitle="Myanmar Internet Censorship & Shutdowns | Internet in Myanmar"
  metaDescription="In-depth analysis of internet censorship, website blocking, and service shutdowns in Myanmar since the 2021 military coup."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Myanmar Internet Censorship & Shutdowns",
    "url": "https://www.internetinmyanmar.com/censorship/",
    "publisher": { "@id": "https://www.internetinmyanmar.com/#organization" },
  })} />
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-danger)] mb-3 uppercase tracking-widest">Censorship & Shutdowns</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Censorship & Shutdowns</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Documenting the Myanmar military junta's systematic use of internet censorship, website blocking, and connectivity shutdowns as instruments of political repression.
    </p>
    <ArticleList articles={combined} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
