---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import ArticleList from '../../components/ArticleList.astro'

export const prerender = true

const articles = (await getCollection('articles', ({ data }) =>
  !data.draft && !data.unlisted && !data.archived && data.categories.includes('Digital Services') && data.lang === 'en'
)).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Base
  title="Digital Services — Myanmar"
  seoTitle="Myanmar Streaming, Apps & Digital Services Guide | Internet in Myanmar"
  metaDescription="Guides to digital services in Myanmar: streaming platforms, mobile payments, e-wallets, e-commerce, and apps available in the country."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="font-mono text-xs text-[color:var(--color-warning)] mb-3 uppercase tracking-widest">Digital Services</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Digital Services</h1>
    <p class="opacity-70 mb-10 max-w-2xl">
      Guides to streaming platforms, mobile payment apps, e-wallets, e-commerce, and other digital services available in Myanmar — including what's blocked and how to access geo-restricted content.
    </p>
    <ArticleList {articles} emptyMessage="No articles published yet in this category." />
  </div>
</Base>
