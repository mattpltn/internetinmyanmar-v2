---
interface ArticleSchema {
  type: 'article'
  headline: string
  datePublished: string
  dateModified?: string
  authorName: string
  authorUrl?: string
  image?: string
  url: string
  description: string
  articleSection?: string
}
interface OrgSchema {
  type: 'organization'
}
type Props = ArticleSchema | OrgSchema

const props = Astro.props
const siteUrl = 'https://www.internetinmyanmar.com'

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsMediaOrganization',
  '@id': `${siteUrl}/#organization`,
  name: 'Internet in Myanmar',
  url: siteUrl,
  description: 'Independent technical monitor of Myanmar\'s digital environment — tracking censorship, internet shutdowns, and connectivity.',
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/og-default.png`,
    width: 1200,
    height: 630,
  },
  foundingDate: '2021',
  areaServed: 'MM',
  knowsAbout: ['internet censorship', 'internet shutdowns', 'digital rights', 'Myanmar telecom'],
  sameAs: [
    'https://twitter.com/InternetMyanmar',
    'https://www.facebook.com/internetinmyanmar',
  ],
  masthead: `${siteUrl}/about/mission/`,
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: 'Internet in Myanmar',
  url: siteUrl,
  description: 'Independent tracking of internet shutdowns, censorship, and connectivity in Myanmar. Real-time OONI data, analysis, and reports.',
  inLanguage: ['en', 'fr', 'es', 'it'],
  publisher: { '@id': `${siteUrl}/#organization` },
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/?s={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
}

const schema = props.type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: props.headline,
  datePublished: props.datePublished,
  dateModified: props.dateModified ?? props.datePublished,
  isAccessibleForFree: true,
  ...(props.articleSection ? { articleSection: props.articleSection } : {}),
  description: props.description,
  url: props.url,
  image: {
    '@type': 'ImageObject',
    url: props.image ? new URL(props.image, siteUrl).href : `${siteUrl}/og-default.png`,
    width: 1200,
    height: 630,
  },
  author: {
    '@type': 'Person',
    '@id': `${siteUrl}/about/sacha-nakeo/#person`,
    name: 'Sacha Nakeo',
    url: props.authorUrl ?? `${siteUrl}/about/sacha-nakeo/`,
  },
  publisher: {
    '@type': 'NewsMediaOrganization',
    '@id': `${siteUrl}/#organization`,
    name: 'Internet in Myanmar',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/og-default.png`,
    },
  },
} : orgSchema
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
{props.type === 'organization' && (
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
)}
